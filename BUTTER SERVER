def find_and_warp_aruco(image):
    """
    Detects ArUco markers in the input image and performs a perspective warp
    to obtain a top-down view of the arena.
    Returns the warped image and the detected marker IDs.

    Raises RuntimeError if less than 4 markers are detected.
    Parameters:
    - image: Input BGR image containing ArUco markers.
    Returns:
    - warped: Warped top-down BGR image of the arena.
    - ids: Numpy array of detected ArUco marker IDs.
    """

    gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))
    gray = clahe.apply(gray)

    aruco_dict = aruco.getPredefinedDictionary(aruco.DICT_4X4_100)
    parameters = aruco.DetectorParameters_create()

    parameters.cornerRefinementMethod = aruco.CORNER_REFINE_SUBPIX
    parameters.adaptiveThreshWinSizeMin = 3
    parameters.adaptiveThreshWinSizeMax = 23
    parameters.adaptiveThreshWinSizeStep = 2
    parameters.adaptiveThreshConstant = 5

    corners, ids, _ = aruco.detectMarkers(gray, aruco_dict, parameters=parameters)

    if ids is None or len(ids) < 4:
        raise RuntimeError("Need at least 4 ArUco markers.")

    aruco.drawDetectedMarkers(image, corners, ids)

    centers = np.array([c[0].mean(axis=0) for c in corners])
    sums = centers.sum(axis=1)
    diffs = np.diff(centers, axis=1)

    top_left_idx, bottom_right_idx = np.argmin(sums), np.argmax(sums)
    top_right_idx, bottom_left_idx = np.argmax(diffs), np.argmin(diffs)

    pts_src = np.zeros((4, 2), dtype=np.float32)
    pts_src[0] = corners[top_left_idx][0][0]
    pts_src[1] = corners[top_right_idx][0][1]
    pts_src[2] = corners[bottom_right_idx][0][2]
    pts_src[3] = corners[bottom_left_idx][0][3]

    pts_dst = np.array(
        [[0, 0], [WIDTH - 1, 0], [WIDTH - 1, HEIGHT - 1], [0, HEIGHT - 1]],
        dtype=np.float32,
    )
    M = cv2.getPerspectiveTransform(pts_src, pts_dst)
    warped = cv2.warpPerspective(image, M, (WIDTH, HEIGHT))

    return warped, ids.flatten()


def find_soil_area(half_image):
    """
    purpose : Calculates the area of soil in the given half-image using HSV color thresholding.
    input : half_image - BGR image representing half of the arena.
    output : soil_area - Integer representing the area of soil detected in the image.
    return : soil_area
    logic: The function converts the input BGR image to HSV color space,
            applies a color threshold to isolate soil regions, and then sums the
                pixels in the resulting mask to calculate the soil area.
    """

    if half_image.size == 0:
        return 0
    hsv = cv2.cvtColor(half_image, cv2.COLOR_BGR2HSV)
    lower_brown = np.array([10, 50, 20])
    upper_brown = np.array([30, 255, 200])
    soil_mask = cv2.inRange(hsv, lower_brown, upper_brown)
    return np.sum(soil_mask)


def apply_clahe(image):
    
    '''
    purpose : Applies CLAHE (Contrast Limited Adaptive Histogram Equalization) to enhance the contrast of the input image.
    input : image - BGR image to be enhanced.
    output : enhanced_image - BGR image after applying CLAHE.
    return : enhanced_image
    logic: The function converts the input BGR image to LAB color space,
            splits the LAB image into its L, A, and B channels,
            applies CLAHE to the L channel to enhance contrast,
            and then merges the enhanced L channel back with the A and B channels before converting back to
    
    '''
    
    lab = cv2.cvtColor(image, cv2.COLOR_BGR2LAB)
    l, a, b = cv2.split(lab)
    clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))
    cl = clahe.apply(l)
    return cv2.cvtColor(cv2.merge((cl, a, b)), cv2.COLOR_LAB2BGR)


def analyze_region_infection(region_image, prefix="P1"):
    
    '''
    propose : Analyzes a given region image to determine the most infected plant block based on yellow color detection.
    input : region_image - BGR image of the plant region to be analyzed.
            prefix - String prefix for labeling the plant blocks (default is "P1").
    output : most_infected - String label of the most infected plant block (e.g.,
                "A", "B", "C", etc.) or "N/A" if no infection is detected.
                visual - BGR image with visual annotations showing detected infections.
    return : most_infected, visual
    logic: The function divides the input region image into six equal blocks,
            applies HSV color thresholding to detect yellow areas in each block,
            calculates the infection score based on the area of detected yellow regions,
            and identifies the block with the highest infection score.
            
    '''
    
    h, w, _ = region_image.shape
    block_h, block_w = h // 3, w // 2
    labels = [["A", "D"], ["B", "E"], ["C", "F"]]
    infection_scores = []
    visual = region_image.copy()

    for c in range(2):
        for r in range(3):
            cell = region_image[
                r * block_h : (r + 1) * block_h, c * block_w : (c + 1) * block_w
            ]
            label = labels[r][c]
            hsv = cv2.cvtColor(cell, cv2.COLOR_BGR2HSV)
            mask = cv2.inRange(hsv, HSV_YELLOW_RANGE[0], HSV_YELLOW_RANGE[1])
            contours, _ = cv2.findContours(
                mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE
            )
            score = 0
            if contours:
                score = max([cv2.contourArea(cnt) for cnt in contours])
                cv2.drawContours(cell, contours, -1, (0, 255, 255), 1)

            cv2.rectangle(
                visual,
                (c * block_w, r * block_h),
                ((c + 1) * block_w, (r + 1) * block_h),
                (255, 0, 0),
                2,
            )
            cv2.putText(
                visual,
                f"{prefix}{label}",
                (c * block_w + 10, r * block_h + 25),
                cv2.FONT_HERSHEY_SIMPLEX,
                0.7,
                (0, 255, 0),
                2,
            )
            infection_scores.append((label, score))

    if not infection_scores:
        return "N/A", visual

    most_infected = max(infection_scores, key=lambda x: x[1])[0]

    for c in range(2):
        for r in range(3):
            if labels[r][c] == most_infected:
                cv2.rectangle(
                    visual,
                    (c * block_w, r * block_h),
                    ((c + 1) * block_w, (r + 1) * block_h),
                    (0, 0, 255),
                    4,
                )
    return most_infected, visual


# ---------------------- Pico server Node ---------------------- #
class WayPointServer(Node):
    def __init__(self):
        """
        purpose: Initializes the WayPointServer node, setting up all ROS 2
                 interfaces and control parameters.
        logic:
        - Sets up state vectors (current, desired) and PID gains.
        - Initializes moving average filters.
        - Creates publishers (command, detection) and subscribers (whycon,
          odometry, image).
        - Initializes the CvBridge.
        - Sets up the ActionServer for 'waypoint_navigation'.
        - Creates ReentrantCallbackGroups for threading.
        - Arms the drone.
        - Starts the main PID control loop timer.
        - Starts a separate thread for preflight infection detection.
        """
        
        super().__init__("waypoint_server")

        # callback groups
        self.pid_or_lqr_callback_group = ReentrantCallbackGroup()
        self.action_callback_group = ReentrantCallbackGroup()

        # state vectors
        self.current_state = [0.0, 0.0, 0.0, 0.0]
        self.desired_state = [0.0, 0.0, 0.0, 0.0]

        # rc command
        self.cmd = SwiftMsgs()
        self.cmd.rc_roll = 1500
        self.cmd.rc_pitch = 1500
        self.cmd.rc_yaw = 1500
        self.cmd.rc_throttle = 1400

        # moving average filter
        self.ma_window = 18
        self.ma_x = deque(maxlen=self.ma_window)
        self.ma_y = deque(maxlen=self.ma_window)
        self.ma_z = deque(maxlen=self.ma_window)

        # PID gains (as before)
        self.Kp = [14.0, 14.0, 16.5, 0]
        self.Ki = [0.000000008, 0.000000008, 1, 0]
        self.Kd = [22.0, 22.0, 32.4, 0]

        self.prev_error = [0.0, 0.0, 0.0]
        self.error_sum = [0.0, 0.0, 0.0]
        self.diff_x = 0.0
        self.diff_y = 0.0
        self.diff_z = 0.0

        self.sample_time = 0.00866
        self.last_time = self.get_clock().now().nanoseconds / 1e9

        # publishers & subscribers
        self.command_pub = self.create_publisher(SwiftMsgs, "/drone_command", 10)
        self.detect_pub = self.create_publisher(String, "/infected_plant_detected", 10)
        self.infected_pub = self.create_publisher(String, "/infected_labels", 10)
        self.movingAvgPublisher = self.create_publisher(
            Vector3, "/moving_average/pose", 10
        )

        self.whycon_sub = self.create_subscription(
            PoseArray, "/whycon/poses", self.whycon_callback, 10
        )
        self.odom_sub = self.create_subscription(
            Odometry, "/rotors/odometry", self.odometry_callback, 10
        )
        self.image_sub = self.create_subscription(
            Image, "/whycon/image_out", self.image_callback, 10
        )

        self.bridge = CvBridge()
        self.current_frame = None

        # detection state
        self.detected_labels = []  # list of strings like "P1C"
        self._detection_done = threading.Event()

        self.is_stabilizing = False

        # action server (preserve original execute behavior)
        self._action_server = ActionServer(
            self,
            NavToWaypoint,
            "waypoint_navigation",
            self.execute_callback,
            callback_group=self.action_callback_group,
        )

        # arm motors & start PID loop
        self.arm()
        self.timer = self.create_timer(
            self.sample_time, self.pid, callback_group=self.pid_or_lqr_callback_group
        )

        # start detection thread (runs once)
        t = threading.Thread(target=self.preflight_detection, daemon=True)
        t.start()

    # ---------------- basic rc helpers ---------------- #
    def disarm(self):
        """
        purpose: Sends the disarm command to the drone.
        logic: Sets RC roll, pitch, yaw, and throttle to 1000 (minimum) and
               RC aux4 (arm switch) to 1000 (disarmed).
               Publishes the resulting SwiftMsgs command.
        """
        self.cmd.rc_roll = 1000
        self.cmd.rc_pitch = 1000
        self.cmd.rc_yaw = 1000
        self.cmd.rc_throttle = 1000
        self.cmd.rc_aux4 = 1000
        self.command_pub.publish(self.cmd)

    def arm(self):
        """
        purpose: Sends the arm command to the drone.
        logic: Calls `disarm()` first to ensure a known state.
               Then sets RC roll, pitch, yaw to 1500 (neutral),
               throttle to 1500 (ready), and aux4 to 2000 (armed).
               Publishes the resulting SwiftMsgs command.
        """
        self.disarm()
        self.cmd.rc_roll = 1500
        self.cmd.rc_pitch = 1500
        self.cmd.rc_yaw = 1500
        self.cmd.rc_throttle = 1500
        self.cmd.rc_aux4 = 2000
        self.command_pub.publish(self.cmd)

    # ---------------- subscriptions --------------------- #
    def whycon_callback(self, msg):
        """
        purpose: Callback for the /whycon/poses topic to update the drone's
                 current position.
        input: msg (geometry_msgs.msg.PoseArray) - The WhyCon pose data.
        logic: Extracts the first pose from the message.
               Applies a simple moving average (SMA) filter using a deque.
               Applies a secondary exponential moving average (EMA/IIR) filter.
               Updates self.current_state[0], [1], and [2] (x, y, z) with the
               filtered position.
               Publishes the filtered position for debugging.
        """
        if not msg.poses:
            return
        p = msg.poses[0]
        self.ma_x.append(p.position.x)
        self.ma_y.append(p.position.y)
        self.ma_z.append(p.position.z)

        fx = sum(self.ma_x) / len(self.ma_x)
        fy = sum(self.ma_y) / len(self.ma_y)
        fz = sum(self.ma_z) / len(self.ma_z)

        self.current_state[0] = 0.2 * fx + 0.8 * self.current_state[0]
        self.current_state[1] = 0.2 * fy + 0.8 * self.current_state[1]
        self.current_state[2] = 0.4 * fz + 0.6 * self.current_state[2]

        self.movingAvgPublisher.publish(
            Vector3(
                x=self.current_state[0],
                y=self.current_state[1],
                z=self.current_state[2],
            )
        )

    def odometry_callback(self, msg):
        """
        purpose: Callback for the /rotors/odometry topic to update the drone's
                 current orientation.
        input: msg (nav_msgs.msg.Odometry) - The odometry data.
        logic: Extracts the orientation quaternion from the message.
               Converts the quaternion to Euler angles (roll, pitch, yaw)
               using `euler_from_quaternion`.
               Stores the roll, pitch, and yaw in degrees as class members.
        """
        q = msg.pose.pose.orientation
        roll, pitch, yaw = euler_from_quaternion([q.x, q.y, q.z, q.w])
        self.roll_deg = math.degrees(roll)
        self.pitch_deg = math.degrees(pitch)
        self.yaw_deg = math.degrees(yaw)

    def image_callback(self, msg):
        """
        purpose: Callback for the /whycon/image_out topic to get the
                 latest camera frame.
        input: msg (sensor_msgs.msg.Image) - The ROS image message.
        logic: Uses the CvBridge (`self.bridge`) to convert the ROS image
               message into an OpenCV BGR8 image.
               Stores the converted frame in `self.current_frame` for
               other threads (like preflight_detection) to access.
        """
        try:
            frame = self.bridge.imgmsg_to_cv2(msg, "bgr8")
            self.current_frame = frame
        except Exception:
            pass

    # ---------------- Task1A detection (runs once at startup) ------------- #
    def preflight_detection(self):
        """
        purpose: Runs *once* at node startup in a separate thread to perform
                 preflight infection detection (Task 1A).
        logic: 1. Waits for the first camera frame from `image_callback`.
               2. Calls `find_and_warp_aruco` to get a top-down view.
               3. Identifies the plant-half of the arena based on soil color.
               4. Crops the two main plant regions (P1, P2).
               5. Enhances contrast using `apply_clahe`.
               6. Calls `analyze_region_infection` for each region to find the
                  most infected plant label (e.g., "P1C", "P2A").
               7. Saves debug images and writes results to `TASK1A_OUTPUT`.
               8. Publishes the final comma-separated list of infected labels
                  (or "NONE") to the `/infected_labels` topic.
               9. Sets `self._detection_done` to signal completion.
        """
        self.get_logger().info(
            "[DETECT] Waiting for first frame from /whycon/image_out..."
        )
        start = time.time()
        while (
            self.current_frame is None
            and (time.time() - start) < FIRST_FRAME_TIMEOUT
            and rclpy.ok()
        ):
            time.sleep(0.05)

        if self.current_frame is None:
            self.get_logger().warn(
                "[DETECT] No frame received within timeout. Publishing NONE and finishing detection."
            )
            self.infected_pub.publish(String(data="NONE"))
            self._detection_done.set()
            return

        frame = self.current_frame.copy()

        # run ArUco warp + detection pipeline
        try:
            warped_arena, ids = find_and_warp_aruco(frame.copy())
        except Exception as e:
            self.get_logger().error(
                f"[DETECT] ArUco detection failed: {e}. Publishing NONE."
            )
            self.infected_pub.publish(String(data="NONE"))
            self._detection_done.set()
            return

        warped_arena = cv2.flip(warped_arena, 1)
        mid_y = warped_arena.shape[0] // 2
        top_half, bottom_half = warped_arena[:mid_y, :], warped_arena[mid_y:, :]

        if find_soil_area(bottom_half) > find_soil_area(top_half):
            plant_area_half = top_half
            self.get_logger().info("Plant trays identified in the BOTTOM half.")
        else:
            plant_area_half = bottom_half
            self.get_logger().info("Plant trays identified in the TOP half.")

        left_region = plant_area_half[66:333, 110:341]
        right_region = plant_area_half[66:333, 460:690]

        left_enhanced = apply_clahe(left_region)
        right_enhanced = apply_clahe(right_region)

        most_infected_b1, vis1 = analyze_region_infection(left_enhanced, "P1")
        most_infected_b2, vis2 = analyze_region_infection(right_enhanced, "P2")

        labels = []
        if most_infected_b1 != "N/A":
            labels.append(f"P1{most_infected_b1}")
        if most_infected_b2 != "N/A":
            labels.append(f"P2{most_infected_b2}")

        self.detected_labels = labels

        # save debug images
        ts = int(time.time())
        try:
            cv2.imwrite(os.path.join(DEBUG_DIR, f"warped_{ts}.png"), warped_arena)
            cv2.imwrite(os.path.join(DEBUG_DIR, f"P1_vis_{ts}.png"), vis1)
            cv2.imwrite(os.path.join(DEBUG_DIR, f"P2_vis_{ts}.png"), vis2)
            self.get_logger().info(f"[DETECT] Debug images saved to {DEBUG_DIR}")
        except Exception as e:
            self.get_logger().warn(f"[DETECT] Failed to save debug images: {e}")

        # publish and optionally save results
        if labels:
            csv = ",".join(labels)
            self.get_logger().info(f"[DETECT] Infected plant labels detected: {labels}")
            try:
                Path(TASK1A_OUTPUT).parent.mkdir(parents=True, exist_ok=True)
                with open(TASK1A_OUTPUT, "w") as f:
                    for L in labels:
                        f.write(L + "\n")
                self.get_logger().info(
                    f"[DETECT] Detection results saved to {TASK1A_OUTPUT}"
                )
            except Exception as e:
                self.get_logger().warn(f"[DETECT] Could not write {TASK1A_OUTPUT}: {e}")
            # publish on topic
            self.infected_pub.publish(String(data=csv))
        else:
            self.get_logger().info("[DETECT] No infected plant detected by Task1A.")
            self.infected_pub.publish(String(data="NONE"))

        self._detection_done.set()
        self.get_logger().info("[DETECT] Preflight detection finished.")

    # ---------------- PID (unchanged) ----------------- #
    def pid(self):
        """
        purpose: The main PID control loop, executed on a timer.
        logic: 1. Calculates the time step `dt`.
               2. Uses a helper function `compute_pid` to calculate the
                  Proportional, Integral, and Derivative components for
                  each axis (X, Y, Z).
               3. Computes separate PID outputs for throttle (Z), pitch (X),
                  and roll (Y) based on `self.desired_state` vs
                  `self.current_state`.
               4. Converts these PID outputs into RC command values (1000-2000
                  range) by adding/subtracting from the 1500 neutral point
                  and a throttle base (`BASE_THR`).
               5. Clamps the throttle value to a safe range.
               6. Publishes the final `SwiftMsgs` command to `/drone_command`.
        """
        now = self.get_clock().now().nanoseconds / 1e9
        dt = now - self.last_time
        if dt <= 0:
            dt = self.sample_time
        self.last_time = now

        def compute_pid(axis, desired, current, prev, isum, diff_prev):
            error = desired - current
            diff = 0.7 * (error - prev) / dt
            isum += error * dt
            output = self.Kp[axis] * error + self.Ki[axis] * isum + self.Kd[axis] * diff
            return output, error, isum, diff_prev

        throttle_output, self.prev_error[2], self.error_sum[2], _ = compute_pid(
            2,
            self.desired_state[2] - 0.1,
            self.current_state[2],
            self.prev_error[2],
            self.error_sum[2],
            self.diff_z,
        )

        pitch_output, self.prev_error[0], self.error_sum[0], _ = compute_pid(
            0,
            self.desired_state[0],
            self.current_state[0],
            self.prev_error[0],
            self.error_sum[0],
            self.diff_y,
        )

        roll_output, self.prev_error[1], self.error_sum[1], _ = compute_pid(
            1,
            self.current_state[1],
            self.desired_state[1],
            self.prev_error[1],
            self.error_sum[1],
            self.diff_x,
        )

        BASE_THR = 1535
        rc_throttle = int(BASE_THR - throttle_output)
        rc_throttle = max(1480, min(1650, rc_throttle))

        self.cmd.rc_throttle = rc_throttle
        self.cmd.rc_pitch = int(1500 + pitch_output)
        self.cmd.rc_roll = int(1500 - roll_output)

        self.command_pub.publish(self.cmd)

    # ---------------- helper actions ----------------- #
    def hover_action(self, label, duration):
        """
        purpose: Blocks execution to make the drone hover at its current
                 location for a specified duration.
        input: label (str) - A label for logging (e.g., "P1A").
               duration (float) - Time to hover in seconds.
        logic: Logs the start of the hover action.
               Uses a `time.sleep()` loop to block for the given `duration`.
               Logs the end of the hover.
               (Note: The PID controller continues running in its own thread,
               holding the drone at `self.desired_state`).
        """
        self.get_logger().info(f"[ACTION] Hovering for {duration}s → {label}")
        t0 = time.time()
        while time.time() - t0 < duration:
            time.sleep(0.05)
        self.get_logger().info(f"[ACTION] Hover complete → {label}")

    def is_drone_in_sphere(self, drone_pos, target_xyz, radius):
        """
        purpose: Checks if the drone is inside a spherical region.
        input: drone_pos (list/tuple) - Current [x, y, z] of the drone.
               target_xyz (list/tuple) - Target [x, y, z] center of the sphere.
               radius (float) - The radius of the sphere.
        output: (bool) - True if the drone is inside or on the sphere,
                         False otherwise.
        return: (bool)
        logic: Calculates the squared Euclidean distance between the drone's
               position and the target position.
               Returns True if this squared distance is less than or equal to
               the squared radius.
        """
        gx, gy, gz = target_xyz
        return (
            (drone_pos[0] - gx) ** 2
            + (drone_pos[1] - gy) ** 2
            + (drone_pos[2] - gz) ** 2
        ) <= radius**2

    # ---------------- execute callback (keeps original behavior) ----------------- #
    def execute_callback(self, goal_handle):
        """
        purpose: Main callback for the 'waypoint_navigation' ActionServer.
                 Executes the logic to move to a waypoint, stabilize,
                 and perform spray actions if necessary.
        input: goal_handle - The ROS 2 action goal handle, containing the
                             target waypoint (Pose).
        output: NavToWaypoint.Result() - The result of the action.
        return: NavToWaypoint.Result()
        logic:
        1.  **Set Target:** Sets `self.desired_state` to the goal's x, y, z,
            and yaw. The PID loop (`pid()`) automatically starts moving
            the drone.
        2.  **Stabilization Loop:** Enters a `while` loop, waiting for the
            drone to enter the `SPHERE_RADIUS` of the target.
            - If the target is one of the `STAB` points, it holds for an
              additional 2.3 seconds.
            - This stabilization is *skipped* if the target is a known
              `PLANT_SPRAY` point.
        3.  Hover/Spray Logic:
            - After stabilization, it checks if the waypoint matches a
              `PLANT_HOVER` coordinate.
            - If it matches a plant (e.g., "P1A"):
                a. Performs a timed `hover_action()`.
                b. Looks up the corresponding `PLANT_SPRAY` coordinate.
                c. Enters a "smooth descent" loop,
                   incrementally lowering `self.desired_state[2]` while
                   correcting X and Y until the spray altitude is reached.
                d. Holds at the final spray coordinate.
                e. Sleeps for `SPRAY_DURATION` to simulate spraying.
        4.  **Complete:** Publishes a confirmation message, sets the
            action to 'succeeded', and returns the result.
        """
        goal = goal_handle.request.waypoint
        self.desired_state[0] = goal.position.x
        self.desired_state[1] = goal.position.y
        self.desired_state[2] = goal.position.z

        q = goal.orientation
        _, _, yaw = euler_from_quaternion([q.x, q.y, q.z, q.w])
        self.desired_state[3] = yaw

        x, y, z = self.desired_state[:3]

        # -------------------------
        # NAVIGATION STABILIZATION
        # -------------------------
        STAB = [(-9.11, 9.27, 31.27), (-9.07, 9.23, 32.57), (8.62, 8.80, 28.69)]

        def near(a, b):
            return math.dist(a, b) < 0.4

        a = (x, y, z)
        do_stab = any(near(a, p) for p in STAB)

        # NEW: skip stabilization if this waypoint is a spray point
        is_spray_point = any(
            abs(sc[0] - x) <= 0.15 and abs(sc[1] - y) <= 0.15
            for sc in PLANT_SPRAY.values()
        )

        stable_start = None

        while rclpy.ok():

            # ---- SKIP STABILIZATION IF SPRAY WAYPOINT ----
            if is_spray_point:
                break

            inside = self.is_drone_in_sphere(
                self.current_state, (x, y, z), SPHERE_RADIUS
            )

            if inside:
                if do_stab:
                    if stable_start is None:
                        stable_start = time.time()
                        self.get_logger().info(
                            "[STABILITY] Inside sphere → starting 2.3s timer"
                        )
                        self.is_stabilizing = True

                    elapsed = time.time() - stable_start
                    self.get_logger().info(f"[STABILITY] {elapsed:.2f} / 2.3s")

                    if elapsed >= 2.3:
                        break
                else:
                    break
            else:
                stable_start = None
                self.is_stabilizing = False

            time.sleep(0.05)

        self.is_stabilizing = False
        self.get_logger().info("[NAV] Reached waypoint successfully")

        # -----------------------------------------------------
        #            PLANT HOVER + SPRAY DETECTION
        # -----------------------------------------------------
        matched_label = None
        for lbl, coord in PLANT_HOVER.items():
            if (
                abs(coord[0] - x) <= PLANT_MATCH_TOL
                and abs(coord[1] - y) <= PLANT_MATCH_TOL
            ):
                matched_label = lbl
                break

        if matched_label is not None:

            # Hover before spraying
            self.get_logger().info(
                f"[PLANT] Hover point matched: {matched_label}. Hovering {HOVER_DURATION}s..."
            )
            self.hover_action(matched_label, HOVER_DURATION)

            spray_coord = PLANT_SPRAY.get(matched_label)
            if spray_coord:
                target_x, target_y, target_z = spray_coord

                self.get_logger().info(
                    "[PLANT] Starting smooth descent with XY correction..."
                )

                while rclpy.ok():
                    # continuous XY correction
                    self.desired_state[0] = target_x
                    self.desired_state[1] = target_y

                    current_z = self.current_state[2]
                    dz = target_z - current_z

                    # smooth descent
                    self.desired_state[2] = current_z - 0.1 + dz * 0.25

                    if abs(dz) < 0.05:
                        break

                    time.sleep(0.05)

                # snap to exact spray position
                self.desired_state[0] = target_x
                self.desired_state[1] = target_y
                self.desired_state[2] = target_z

                # short wait inside sphere
                t0 = time.time()
                while rclpy.ok() and (time.time() - t0) < 3.0:
                    if self.is_drone_in_sphere(
                        self.current_state, tuple(spray_coord), SPHERE_RADIUS
                    ):
                        break
                    time.sleep(0.05)

                # SPRAY
                self.get_logger().info(
                    f"[PLANT] Spraying {matched_label} for {SPRAY_DURATION}s..."
                )
                time.sleep(SPRAY_DURATION)

            else:
                self.get_logger().warn(
                    f"[PLANT] No spray coordinate for {matched_label}"
                )

        else:
            self.get_logger().warn(
                f"[PLANT] No spray coordinate found for {matched_label}"
            )

        # publish
        try:
            self.detect_pub.publish(String(data="Waypoint reached"))
        except Exception:
            pass

        goal_handle.succeed()
        return NavToWaypoint.Result()


# ---------------------- entrypoint ---------------------- #
def main(args=None):
    """
    purpose: The main entry point for launching the ROS 2 node.
    input: args (list, optional) - Command-line arguments.
    logic: 1. Initializes rclpy.
           2. Creates an instance of the `WayPointServer` node.
           3. Creates a `MultiThreadedExecutor` to allow callbacks (PID
              timer, subscriptions, action server) to run in parallel.
           4. Adds the node to the executor.
           5. Spins the executor (blocks) to keep the node alive.
           6. Catches `KeyboardInterrupt` (Ctrl+C) for shutdown.
           7. Cleans up by destroying the node and shutting down rclpy.
    """
    rclpy.init(args=args)
    node = WayPointServer()
    executor = MultiThreadedExecutor()
    executor.add_node(node)

    try:
        executor.spin()
    except KeyboardInterrupt:
        pass
    finally:
        # proper cleanup
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()

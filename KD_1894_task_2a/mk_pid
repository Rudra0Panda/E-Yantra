#!/usr/bin/env python3
"""
Stable ROS2 PID controller for Swift Pico drone
------------------------------------------------
This version improves altitude (Z-axis) stability using:
  • Low-pass filter on WhyCon altitude data
  • Refined PID values (Ziegler–Nichols refined)
  • Smoother throttle output filtering
  • Anti-windup and coupling compensation
  • Throttle clamp and waypoint-change integral freeze
  • Derivative spike limiting for Z-axis
"""

import math
import rclpy
from rclpy.node import Node
from swift_msgs.msg import SwiftMsgs
from geometry_msgs.msg import PoseArray, Vector3
from controller_msg.msg import PIDTune
from error_msg.msg import Error


class Swift_Pico(Node):
    def __init__(self):
        super().__init__('pico_controller')

        # --- Desired vs Current ---
        self.current_state = [0.0, 0.0, 0.0]
        self.desired_state = [0.0, 0.0, 0.0]

        # --- PID constants (Pitch, Roll, Throttle) ---
        self.Kp = [6, 3, 16.0]
        self.Ki = [0.0, 0.0, 1.2]
        self.Kd = [3, 8, 32.0]

        # --- Internal PID state ---
        self.prev_error = [0.0, 0.0, 0.0]
        self.error_sum = [0.0, 0.0, 0.0]
        self.prev_output = [1500, 1500, 1500]

        self.diff_x = 0.0
        self.diff_y = 0.0
        self.diff_z = 0.0

        # --- RC Command ---
        self.cmd = SwiftMsgs()
        self.reset_rc()

        # --- RC limits ---
        self.max_values = [2000, 2000, 2000]
        self.min_values = [1000, 1000, 1000]

        # --- Timing ---
        self.sample_time = 0.03  # seconds
        self.last_time = self.get_clock().now().nanoseconds / 1e9

        # --- Filters & constants ---
        self.alpha = 0.35           # output smoothing for pitch/roll
        self.alpha_throttle = 0.90  # stronger smoothing for throttle
        self.beta = 0.80             # derivative filter
        self.integral_limit = 10.0
        self.deadband = 0.18
        self.alpha_z_filter = 0.70  # filter for noisy Z readings

        # --- Waypoint integral freeze ---
        self.last_waypoint_change_time = self.last_time
        self.waypoint_freeze_time = 0.60  # seconds

        # --- Publishers ---
        self.command_pub = self.create_publisher(SwiftMsgs, '/drone_command', 10)
        self.pos_error_pub = self.create_publisher(Error, '/pos_error', 10)

        # --- Subscribers ---
        self.create_subscription(PoseArray, '/whycon/poses', self.whycon_callback, 1)
        self.create_subscription(PIDTune, '/throttle_pid', self.altitude_set_pid, 1)
        self.create_subscription(PIDTune, '/pitch_pid', self.pitch_set_pid, 1)
        self.create_subscription(PIDTune, '/roll_pid', self.roll_set_pid, 1)
        self.create_subscription(Vector3, '/desired_state', self.updateDesiredState, 1)

        self.stable_counter = 0

        # --- Arm and start control ---
        self.arm()
        self.create_timer(self.sample_time, self.pid)
        self.get_logger().info("🧭 Stable Swift Pico Controller started (Z-optimized)")

    # ---------------- Arm/Disarm ----------------
    def updateDesiredState(self, msg: Vector3):
        # Detect waypoint change
        if [msg.x, msg.y, msg.z] != self.desired_state:
            self.last_waypoint_change_time = self.get_clock().now().nanoseconds / 1e9
        self.desired_state = [msg.x, msg.y, msg.z]

    def disarm(self):
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1000
        self.cmd.rc_aux4 = 1000
        self.command_pub.publish(self.cmd)
        self.get_logger().info("Drone disarmed")

    def arm(self):
        self.disarm()
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1500
        self.cmd.rc_aux4 = 2000
        self.command_pub.publish(self.cmd)
        self.get_logger().info("Drone armed ✅")

    def reset_rc(self):
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1500
        self.cmd.rc_aux4 = 1500

    # ---------------- PID tuning updates ----------------
    def altitude_set_pid(self, msg):
        self.Kp[2] = msg.kp
        self.Ki[2] = msg.ki / 150  # stronger integral scaling for Z
        self.Kd[2] = msg.kd

    def pitch_set_pid(self, msg):
        self.Kp[0] = msg.kp
        self.Ki[0] = msg.ki / 250
        self.Kd[0] = msg.kd

    def roll_set_pid(self, msg):
        self.Kp[1] = msg.kp
        self.Ki[1] = msg.ki / 250
        self.Kd[1] = msg.kd

    # ---------------- Pose callback (with Z-filter) ----------------
    def whycon_callback(self, msg: PoseArray):
        if msg.poses:
            pose = msg.poses[0].position
            # Smooth Z readings to reduce throttle twitch
            self.current_state[2] = (
                self.alpha_z_filter * self.current_state[2] + (1 - self.alpha_z_filter) * pose.z
            )
            self.current_state[0] = pose.x
            self.current_state[1] = pose.y

    # ---------------- PID loop ----------------
    def pid(self):
        now = self.get_clock().now().nanoseconds / 1e9
        dt = max(self.sample_time, now - self.last_time)
        self.last_time = now

        freeze_integral = (now - self.last_waypoint_change_time) < self.waypoint_freeze_time

        def safe_num(x, default=0.0):
            try:
                if x is None or not math.isfinite(x):
                    return default
                return float(x)
            except Exception:
                return default

        def compute_pid(axis, desired, current, prev_err, err_sum, diff_prev):
            prev_err = safe_num(prev_err, 0.0)
            diff_prev = safe_num(diff_prev, 0.0)
            error = desired - current

            if axis == 2 and abs(error) < 0.12:
                error = 0.0
            elif abs(error) < self.deadband:
                error = 0.0

            diff_raw = (error - prev_err) / dt if dt > 0 else 0.0
            diff_filtered = self.beta * diff_prev + (1 - self.beta) * diff_raw

            # Integrate only if allowed
            if axis != 2 and abs(error) > self.deadband:
                err_sum += error * dt
            if axis == 2 and not freeze_integral:
                err_sum += error * dt

            # Clamp integral
            err_sum = max(-self.integral_limit, min(self.integral_limit, err_sum))

            output = (self.Kp[axis] * error +
                      self.Ki[axis] * err_sum +
                      self.Kd[axis] * diff_filtered)

            return float(output), float(error), float(err_sum), float(diff_filtered)

        # --- Pitch ---
        out_x, ex, self.error_sum[0], self.diff_x = compute_pid(
            0, self.desired_state[0], self.current_state[0],
            self.prev_error[0], self.error_sum[0], self.diff_x
        )

        # --- Roll (reversed logic retained) ---
        out_y, ey, self.error_sum[1], self.diff_y = compute_pid(
            1, self.current_state[1], self.desired_state[1],
            self.prev_error[1], self.error_sum[1], self.diff_y
        )

        # --- Throttle (Z-axis) ---
        out_z, ez, self.error_sum[2], self.diff_z = compute_pid(
            2, self.desired_state[2], self.current_state[2],
            self.prev_error[2], self.error_sum[2], self.diff_z
        )

        # --- Limit derivative spike for Z ---
        max_diff_z = 2.0
        self.diff_z = max(-max_diff_z, min(max_diff_z, self.diff_z))

        # --- Velocity damping ---
        out_z -= 0.08 * self.diff_z

        # --- Feed-forward coupling ---
        out_z -= 0.12 * out_x

        # --- RC mapping & smoothing ---
        rc_thr_raw = 1500 - out_z
        rc_pitch_raw = 1500 + out_x
        rc_roll_raw = 1500 - out_y

        rc_thr = int(self.alpha_throttle * self.prev_output[2] + (1 - self.alpha_throttle) * rc_thr_raw)
        rc_pitch = int(self.alpha * self.prev_output[0] + (1 - self.alpha) * rc_pitch_raw)
        rc_roll = int(self.alpha * self.prev_output[1] + (1 - self.alpha) * rc_roll_raw)

        # --- Clamp all RC values ---
        rc_thr = max(self.min_values[2], min(self.max_values[2], rc_thr))
        rc_pitch = max(self.min_values[0], min(self.max_values[0], rc_pitch))
        rc_roll = max(self.min_values[1], min(self.max_values[1], rc_roll))

        # --- Publish RC commands ---
        self.cmd.rc_throttle = rc_thr
        self.cmd.rc_pitch = rc_pitch
        self.cmd.rc_roll = rc_roll
        self.cmd.rc_yaw = 1500
        self.command_pub.publish(self.cmd)

        # --- Stability detection ---
        z_err = self.desired_state[2] - self.current_state[2]
        horiz_err = math.hypot(
            self.desired_state[0] - self.current_state[0],
            self.desired_state[1] - self.current_state[1]
        )

        if abs(z_err) < 0.25 and abs(self.diff_z) < 0.04:
            self.stable_counter += 1
        else:
            self.stable_counter = 0

        if self.stable_counter > int(3.0 / self.sample_time):
            self.get_logger().info("✅ Altitude stable for 3 s")

        self.prev_error = [ex, ey, ez]
        self.prev_output = [rc_pitch, rc_roll, rc_thr]

        if int(now * 2) % 10 == 0:
            self.get_logger().info(
                f"Herr:{horiz_err:.3f}  Z:{self.current_state[2]:.3f}/{self.desired_state[2]:.3f}  "
                f"Thr:{self.cmd.rc_throttle}  Pitch:{self.cmd.rc_pitch}  Roll:{self.cmd.rc_roll}"
            )


def main(args=None):
    rclpy.init(args=args)
    node = Swift_Pico()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        node.get_logger().info("Controller stopped.")
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()

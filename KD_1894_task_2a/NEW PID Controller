#!/usr/bin/env python3
"""
Stable ROS2 PID controller for Swift Pico drone.
FINAL TUNING: Pitch, Roll, and Throttle tuned for critical damping and high performance.
Derivative Noise in Throttle (Z) fixed using a targeted, higher-order filter coefficient (beta=0.98).
"""

import math
import rclpy
from rclpy.node import Node
# ----------------- NEW IMPORTS FOR YAW CONTROL -----------------
from nav_msgs.msg import Odometry
from tf_transformations import euler_from_quaternion
# ---------------------------------------------------------------
from swift_msgs.msg import SwiftMsgs
from geometry_msgs.msg import PoseArray
from controller_msg.msg import PIDTune
from error_msg.msg import Error
from geometry_msgs.msg import Vector3


class Swift_Pico(Node):
    def __init__(self):
        super().__init__('pico_controller')

        # --- Desired vs Current (X, Y, Z, Yaw) ---
        self.current_state = [0.0, 0.0, 0.0]
        self.desired_state = [0.0, 0.0, 0.0]
        self.current_yaw = 0.0

        # --- DYNAMIC YAW BASELINE FIX ---
        self.desired_yaw = None
        self.initial_yaw_set = False
        # --------------------------------

        # --- PID constants (FINAL CRITICALLY DAMPED GAINS) ---
        # [Pitch (X), Roll (Y), Throttle (Z), Yaw (Index 3)]
        self.Kp = [10.0, 8.0, 22.0, 0.5]
        self.Ki = [0.30, 0.35, 5.0, 0.05]
        self.Kd = [7.5, 12.0, 40.0, 0.01]

        # --- Internal PID state ---
        # [X, Y, Z, Yaw]
        self.prev_error = [0.0, 0.0, 0.0, 0.0]
        self.error_sum = [0.0, 0.0, 0.0, 0.0]
        self.prev_output = [1500, 1500, 1500, 1500]

        # --- Derivative filters ---
        self.diff_x = 0.0
        self.diff_y = 0.0
        self.diff_z = 0.0
        self.diff_yaw = 0.0

        # --- RC Command ---
        self.cmd = SwiftMsgs()
        self.reset_rc()

        # --- RC limits ---
        self.max_values = [2000, 2000, 2000, 2000]
        self.min_values = [1000, 1000, 1000, 1000]

        # --- Control Timing ---
        self.sample_time = 0.03  # seconds
        self.last_time = self.get_clock().now().nanoseconds / 1e9

        # --- Fixed filter/smoothing constants ---
        self.alpha = 0.35
        self.beta = 0.90  # Kept lower for fast X/Y response
        self.integral_limit = 60.0
        self.deadband = 0.20

        # --- Publishers ---
        self.command_pub = self.create_publisher(SwiftMsgs, '/drone_command', 10)
        self.pos_error_pub = self.create_publisher(Error, '/pos_error', 10)

        # --- Subscribers ---
        self.create_subscription(PoseArray, '/whycon/poses', self.whycon_callback, 1)
        self.create_subscription(Odometry, '/rotors/odometry', self.odometry_callback, 1)
        self.create_subscription(PIDTune, '/throttle_pid', self.altitude_set_pid, 1)
        self.create_subscription(PIDTune, '/pitch_pid', self.pitch_set_pid, 1)
        self.create_subscription(PIDTune, '/roll_pid', self.roll_set_pid, 1)
        self.create_subscription(Vector3, '/desired_state', self.updateDesiredState, 1)

        # stability counter for detecting stable hover
        self.stable_counter = 0

        # --- Arm and start control ---
        self.arm()
        self.create_timer(self.sample_time, self.pid)
        self.get_logger().info("🧭 Stable Swift Pico Controller started (fixed smoothing)")

    # ---------------- Arm/Disarm & State Update ----------------
    def updateDesiredState(self, msg: Vector3):
        self.desired_state = [msg.x, msg.y, msg.z]

    def disarm(self):
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1000
        self.cmd.rc_aux4 = 1000
        self.command_pub.publish(self.cmd)
        self.get_logger().info("Drone disarmed")

    def arm(self):
        self.disarm()
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1500
        self.cmd.rc_aux4 = 2000
        self.command_pub.publish(self.cmd)
        self.get_logger().info("Drone armed ✅")

    def reset_rc(self):
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1500
        self.cmd.rc_aux4 = 1500

    # ---------------- PID tuning updates ----------------
    def altitude_set_pid(self, msg):
        self.Kp[2] = msg.kp
        self.Ki[2] = msg.ki / 250
        self.Kd[2] = msg.kd
        self.get_logger().info(f"Updated Altitude PID: Kp={self.Kp[2]}, Ki={self.Ki[2]}, Kd={self.Kd[2]}")

    def pitch_set_pid(self, msg):
        self.Kp[0] = msg.kp
        self.Ki[0] = msg.ki / 250
        self.Kd[0] = msg.kd
        self.get_logger().info(f"Updated Pitch PID: Kp={self.Kp[0]}, Ki={self.Ki[0]}, Kd={self.Kd[0]}")

    def roll_set_pid(self, msg):
        self.Kp[1] = msg.kp
        self.Ki[1] = msg.ki / 250
        self.Kd[1] = msg.kd
        self.get_logger().info(f"Updated Roll PID: Kp={self.Kp[1]}, Ki={self.Ki[1]}, Kd={self.Kd[1]}")

    # ---------------- Yaw Odometry Callback (DYNAMIC BASELINE) ----------------
    def odometry_callback(self, msg: Odometry):
        orientation_q = msg.pose.pose.orientation
        orientation_list = [orientation_q.x, orientation_q.y, orientation_q.z, orientation_q.w]
        (roll, pitch, yaw) = euler_from_quaternion(orientation_list)

        self.current_yaw = yaw

        # --- FIX: Capture initial yaw as the desired yaw only once ---
        if not self.initial_yaw_set:
            self.desired_yaw = self.current_yaw
            self.initial_yaw_set = True
            self.get_logger().info(f"Initial Yaw Baseline set to: {math.degrees(self.desired_yaw):.2f}°")
        # -----------------------------------------------------------

    # ---------------- Pose callback (WhyCon) ----------------
    def whycon_callback(self, msg: PoseArray):
        if msg.poses:
            pose = msg.poses[0].position
            self.current_state = [pose.x, pose.y, pose.z]

    # ---------------- PID loop ----------------
    def pid(self):
        now = self.get_clock().now().nanoseconds / 1e9
        dt = max(self.sample_time, now - self.last_time)
        self.last_time = now

        def safe_num(x, default=0.0):
            try:
                if x is None:
                    return default
                if not math.isfinite(x):
                    return default
                return float(x)
            except Exception:
                return default

        def compute_pid(axis, desired, current, prev_err, err_sum, diff_prev):
            prev_err = safe_num(prev_err, 0.0)
            diff_prev = safe_num(diff_prev, 0.0)

            error = desired - current

            # YAW WRAP-AROUND (Axis 3)
            if axis == 3:
                error = math.atan2(math.sin(error), math.cos(error))

            # Axis-specific deadbands
            if axis == 2 and abs(error) < 0.05:
                error = 0.0
            elif abs(error) < self.deadband:
                error = 0.0

            # ----------------- TARGETED DERIVATIVE FILTER FIX -----------------
            beta_effective = self.beta
            if axis == 2:  # Z-axis (Throttle)
                # Use a much higher beta to aggressively smooth noisy altitude derivative
                beta_effective =  0.98  # ------------------------------------------------------------------

            # Derivative term (raw and filtered)
            diff_raw = (error - prev_err) / dt if dt > 0 else 0.0
            diff_filtered = beta_effective * diff_prev + (1.0 - beta_effective) * diff_raw

            # Integral handling
            if axis != 2:
                if abs(error) > self.deadband:
                    err_sum += error * dt

            # clamp integral
            if not math.isfinite(err_sum):
                err_sum = 0.0
            err_sum = max(-self.integral_limit, min(self.integral_limit, err_sum))

            # PID output
            output = (self.Kp[axis] * error +
                      self.Ki[axis] * err_sum +
                      self.Kd[axis] * diff_filtered)
            return float(output), float(error), float(err_sum), float(diff_filtered)

            


        # --- Compute Pitch and Roll ---
        out_x, ex, self.error_sum[0], self.diff_x = compute_pid(
            0, self.desired_state[0], self.current_state[0],
            self.prev_error[0], self.error_sum[0],
            getattr(self, "diff_x", 0.0)
        )

        out_y, ey, self.error_sum[1], self.diff_y = compute_pid(
            1, self.current_state[1], self.desired_state[1],
            self.prev_error[1], self.error_sum[1],
            getattr(self, "diff_y", 0.0)
        )

        # --- Compute Yaw (Conditional on baseline being set) ---
        ez_yaw = 0.0
        rc_yaw = 1500

        if self.desired_yaw is not None:
            out_yaw, ez_yaw, self.error_sum[3], self.diff_yaw = compute_pid(
                3, self.desired_yaw, self.current_yaw,
                self.prev_error[3], self.error_sum[3],
                getattr(self, "diff_yaw", 0.0)
            )
            rc_yaw = 1500 + out_yaw
        # -----------------------------------------------------

        # --- Throttle (Z) adaptive handling ---
        z_err = self.desired_state[2] - self.current_state[2]
        altitude_error_abs = abs(z_err)

        horiz_err = math.hypot(self.desired_state[0] - self.current_state[0],
                               self.desired_state[1] - self.current_state[1])

        horizontal_motion_threshold = 0.15
        pitch_activity_threshold = 8.0
        pitch_activity = abs(out_x)

        throttle_integrate = not (horiz_err > horizontal_motion_threshold or pitch_activity > pitch_activity_threshold)

        thr_err_sum = safe_num(self.error_sum[2], 0.0)
        
        out_z_tmp, ez_tmp, _, diff_z_tmp = compute_pid(
            2, self.desired_state[2], self.current_state[2],
            self.prev_error[2], thr_err_sum,
            getattr(self, "diff_z", 0.0)
        )
        self.diff_z = safe_num(diff_z_tmp, 0.0)
        ez = safe_num(ez_tmp, 0.0)

        if throttle_integrate and abs(ez) > 0.02:
            thr_err_sum += ez * dt

        thr_err_sum = max(-self.integral_limit, min(self.integral_limit, thr_err_sum))
        self.error_sum[2] = thr_err_sum

        out_z, ez, self.error_sum[2], self.diff_z = compute_pid(
            2, self.desired_state[2], self.current_state[2],
            self.prev_error[2], self.error_sum[2],
            getattr(self, "diff_z", 0.0)
        )

        # Coupling compensation
        k_couple = 0.08
        coupling_comp = k_couple * out_x
        out_z -= coupling_comp

        # --- RC mapping ---
        rc_thr = 1500 - out_z
        rc_pitch = 1500 + out_x
        rc_roll = 1500 - out_y
        # rc_yaw is already calculated above (conditionally)

        # --- Output smoothing ---
        alpha_throttle = 0.50
        rc_thr = int(alpha_throttle * self.prev_output[2] + (1.0 - alpha_throttle) * rc_thr)
        rc_pitch = int(self.alpha * self.prev_output[0] + (1.0 - self.alpha) * rc_pitch)
        rc_roll = int(self.alpha * self.prev_output[1] + (1.0 - self.alpha) * rc_roll)
        rc_yaw = int(self.alpha * self.prev_output[3] + (1.0 - self.alpha) * rc_yaw)

        # --- Clamp RC values ---
        self.cmd.rc_throttle = max(self.min_values[2], min(self.max_values[2], rc_thr))
        self.cmd.rc_pitch = max(self.min_values[0], min(self.max_values[0], rc_pitch))
        self.cmd.rc_roll = max(self.min_values[1], min(self.max_values[1], rc_roll))
        self.cmd.rc_yaw = max(self.min_values[3], min(self.max_values[3], rc_yaw))

        # publish command
        self.command_pub.publish(self.cmd)

        # --- Stability detection ---
        if altitude_error_abs < 0.25 and abs(self.diff_z) < 0.04:
            self.stable_counter += 1
        else:
            self.stable_counter = 0

        if self.stable_counter > int(3.0 / max(self.sample_time, 0.01)):
            self.get_logger().info("✅ Altitude stable at waypoint (3s)")

        # --- Save for next loop ---
        # Ensure we save the correct yaw output and error
        yaw_error_to_save = ez_yaw
        yaw_output_to_save = rc_yaw

        self.prev_error = [ex, ey, ez, yaw_error_to_save]
        self.prev_output = [rc_pitch, rc_roll, rc_thr, yaw_output_to_save]

        # Periodic log
        if int(now * 2) % 2 == 0:
            self.get_logger().info(
                f"Herr:{horiz_err:.3f} Z:{self.current_state[2]:.3f}/{self.desired_state[2]:.3f} "
                f"Thr:{self.cmd.rc_throttle} | Pit:{self.cmd.rc_pitch} | Rol:{self.cmd.rc_roll} | Yaw:{self.cmd.rc_yaw}"
            )


def main(args=None):
    rclpy.init(args=args)
    node = Swift_Pico()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        node.get_logger().info("Controller stopped.")
    finally:
        node.destroy_node()
        rclpy.shutdown()


if __name__ == '__main__':
    main()

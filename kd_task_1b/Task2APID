#!/usr/bin/env python3

import rclpy
from rclpy.node import Node
from geometry_msgs.msg import PoseArray
from swift_msgs.msg import SwiftMsgs
import numpy as np
import math


class SwiftPico(Node):
    """ROS2 node for autonomous waypoint navigation using PID control."""

    def __init__(self):
        super().__init__('pico_controller')

        # PID gains (X, Y, Z)
        self.Kp = [0.0, 0.0, 0.0]
        self.Ki = [0.0, 0.0, 0.0]
        self.Kd = [0.0, 0.0, 0.0]

        # Yaw PID
        self.Kp_yaw = 0.0
        self.Ki_yaw = 0.0
        self.Kd_yaw = 0.0

        # State variables
        self.prev_error = [0.0, 0.0, 0.0]
        self.integral = [0.0, 0.0, 0.0]
        self.prev_error_yaw = 0.0
        self.integral_yaw = 0.0

        # Waypoints: (x, y, z)
        self.waypoints = [
            [-7.00, 0.00, 29.22],
            [-7.64, 3.06, 29.22],
            [-8.22, 6.02, 29.22],
            [-9.11, 9.27, 29.27],
            [-5.98, 8.81, 29.27],
            [-3.26, 8.41, 29.88],
            [0.87, 8.18, 29.05],
            [3.93, 7.35, 29.05],
        ]
        self.current_wp = 0
        self.waypoint_tolerance = 0.35
        self.desired_state = self.waypoints[0]
        self.hover_mode = False

        # Hover behavior
        self.hover_tolerance = 0.12
        self.hover_duration = 3.0
        self.stable_start_time = None
        self.last_positions = []

        # ROS2 publishers/subscribers
        self.cmd_pub = self.create_publisher(SwiftMsgs, '/drone_command', 10)
        self.pose_sub = self.create_subscription(PoseArray, '/whycon/poses', self.pose_callback, 10)

        # Control loop timer
        self.timer = self.create_timer(0.05, self.pid_loop)

        # Initialize state
        self.current_state = [0.0, 0.0, 0.0]
        self.last_time = self.get_clock().now().nanoseconds * 1e-9

        self.get_logger().info("✅ SwiftPico PID Controller initialized.")

    # ---------------- Pose callback ---------------- #
    def pose_callback(self, msg):
        if msg.poses:
            pose = msg.poses[0]
            self.current_state = [pose.position.x, pose.position.y, pose.position.z]

    # ---------------- PID main loop ---------------- #
    def pid_loop(self):
        if self.hover_mode:
            self.cmd_pub.publish(self.hover_cmd())
            return

        target = self.waypoints[self.current_wp]

        # Smooth transition toward target
        alpha = 0.12
        self.desired_state = [
            self.desired_state[i] + alpha * (target[i] - self.desired_state[i])
            for i in range(3)
        ]

        now = self.get_clock().now().nanoseconds * 1e-9
        dt = min(max(now - self.last_time, 0.002), 0.05)
        self.last_time = now

        # Compute PID for X, Y, Z
        outputs = []
        for i in range(3):
            error = self.desired_state[i] - self.current_state[i]
            self.integral[i] += error * dt
            derivative = (error - self.prev_error[i]) / dt

            output = (
                self.Kp[i] * error +
                self.Ki[i] * self.integral[i] +
                self.Kd[i] * derivative
            )
            output = np.clip(output, -120, 120)
            outputs.append(output)
            self.prev_error[i] = error

        # Compute desired yaw
        dx = target[0] - self.current_state[0]
        dy = target[1] - self.current_state[1]
        desired_yaw = math.degrees(math.atan2(dy, dx))

        current_yaw = 1500
        error_yaw = desired_yaw - (current_yaw - 1500)
        error_yaw = (error_yaw + 180) % 360 - 180

        yaw_output = np.clip(
            self.Kp_yaw * error_yaw +
            self.Ki_yaw * self.integral_yaw +
            self.Kd_yaw * (error_yaw - self.prev_error_yaw) / dt,
            -120, 120
        )
        self.prev_error_yaw = error_yaw

        # Publish command
        cmd = SwiftMsgs()
        cmd.rc_roll = int(1500 + outputs[0])
        cmd.rc_pitch = int(1500 - outputs[1])
        cmd.rc_throttle = int(1500 + outputs[2])
        cmd.rc_yaw = int(1500 + yaw_output)
        self.cmd_pub.publish(cmd)

        self.get_logger().info(
            f"WP {self.current_wp + 1}/{len(self.waypoints)} | "
            f"Target: {np.round(target, 2)} | Pos: {np.round(self.current_state, 2)} | "
            f"σ: {np.round(pos_std, 3)} | Stable: {stable}"
        )

    # ---------------- Hover command ---------------- #
    def hover_cmd(self):
        msg = SwiftMsgs()
        msg.rc_pitch = msg.rc_roll = msg.rc_yaw = 1500
        msg.rc_throttle = 1500
        return msg


def main(args=None):
    rclpy.init(args=args)
    node = SwiftPico()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    node.destroy_node()
    rclpy.shutdown()


if __name__ == '__main__':
    main()


#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from geometry_msgs.msg import Pose
from waypoint_navigation.srv import GetWaypoints
import os


INFECTED_FILE = os.path.expanduser("~/pico_ws/infected_plants.txt")


# Hover + Spray coordinates for the plants
HOVER_COORDS = {
    "P1A": [4.39, 8.98, 29.29],
    "P1B": [6.45, 8.79, 28.67],
    "P1C": [8.62, 8.80, 28.69],
    "P1D": [4.37, 4.57, 29.19],
    "P1E": [6.76, 4.49, 28.77],
    "P1F": [8.70, 4.53, 28.97],

    "P2A": [4.43, -4.30, 29.74],
    "P2B": [6.68, -4.30, 29.74],
    "P2C": [8.93, -4.30, 29.74],
    "P2D": [4.58, -8.78, 30.62],
    "P2E": [6.76, -8.61, 30.03],
    "P2F": [9.17, -8.61, 30.03],
}

SPRAY_COORDS = {
    "P1A": [4.5, 8.88, 30.59],
    "P1B": [6.85, 8.89, 30.62],
    "P1C": [9.13, 8.80, 30.40],
    "P1D": [4.53, 4.57, 30.79],
    "P1E": [6.45, 4.57, 30.79],
    "P1F": [9.1, 4.53, 28.97],

    "P2A": [4.43, -4.30, 31.10],
    "P2B": [7.05, -4.30, 31.52],
    "P2C": [9.32, -4.30, 31.06],
    "P2D": [4.53, -8.59, 30.76],
    "P2E": [7.05, -8.81, 31.52],
    "P2F": [9.08, -8.92, 31.93],
}



class FullMissionWaypointService(Node):
    def __init__(self):
        super().__init__("waypoints_service_task2b_final")
        self.srv = self.create_service(GetWaypoints, "waypoints", self.waypoint_callback)
        self.get_logger().info("🧭 Infected Mission Waypoint Service Ready")

    def read_infected_labels(self):
        """Reads infected plant labels detected by pico server."""
        if not os.path.exists(INFECTED_FILE):
            self.get_logger().warn("⚠️ infected_plants.txt not found — returning no plant waypoints.")
            return []

        labels = []
        try:
            with open(INFECTED_FILE, "r") as f:
                for line in f:
                    L = line.strip()
                    if L:
                        labels.append(L)
        except Exception as e:
            self.get_logger().error(f"❌ Error reading infected file: {e}")
            return []

        return labels


    def waypoint_callback(self, request, response):

        if not request.get_waypoints:
            self.get_logger().warn("⚠️ get_waypoints=False — returning no waypoints.")
            return response

        wp = []

        # -----------------------------------------------------
        # 1. Ground → Pesticide Station 2
        # -----------------------------------------------------
        wp += [
            [-6.9, 0.09, 32.16],
            [-7.0, 0.0, 30.22],
            [-7.49, -2.83, 30.22],
            [-7.82, -5.55, 30.22],
            [-8.62, -8.6, 29.6],
            [-8.53, -8.52, 30.64]
        ]

        # -----------------------------------------------------
        # 2. Ground → Pesticide Station 1
        # -----------------------------------------------------
        wp += [
            [-7.0, 0.0, 30.22],
            [-7.64, 3.06, 30.22],
            [-8.22, 6.02, 30.22],
            [-9.11, 9.27, 31.27],
            [-9.07, 9.23, 32.57]
        ]

        # -----------------------------------------------------
        # 3. Pesticide Station 1 → Block 1
        # -----------------------------------------------------
        wp += [
            [-5.976, 8.810, 31.27],
            [-3.26, 8.41, 29.88],
            [0.87, 8.18, 29.05],
            [3.929, 7.347, 29.05],
            [6.60, 6.62, 30.20]
        ]

        # -----------------------------------------------------
        # 4. Add ONLY INFECTED plant hover + spray coordinates
        # -----------------------------------------------------
        infected = self.read_infected_labels()

        if infected:
            self.get_logger().info(f"🌿 Infected plants found: {infected}")
        else:
            self.get_logger().warn("⚠️ No infected plants — skipping plant sequence.")

        for lbl in infected:
            if lbl in HOVER_COORDS:
                wp.append(HOVER_COORDS[lbl])   # hover
                wp.append(SPRAY_COORDS[lbl])   # spray
            else:
                self.get_logger().warn(f"Unknown label {lbl}, skipping.")

        # -----------------------------------------------------
        # 5. Block 1 → Block 2
        # -----------------------------------------------------
        wp += [
            [6.7375, 3.3200, 30.6450],
            [6.8750, -0.1900, 30.0900],
            [7.0125, -3.5950, 31.5350],
            [7.15, -7.00, 31.98]
        ]

        # -----------------------------------------------------
        # 6. Block 2 → Pesticide Station 2
        # -----------------------------------------------------
        wp += [
            [4.0, -7.62, 30.59],
            [0.8, -8.04, 29.20],
            [-3.26, -8.12, 29.48],
            [-5.94, -8.36, 29.54],
            [-8.62, -8.6, 29.6]
        ]

        # Fill response
        response.waypoints.poses = [Pose() for _ in range(len(wp))]
        for i, (x, y, z) in enumerate(wp):
            response.waypoints.poses[i].position.x = x
            response.waypoints.poses[i].position.y = y
            response.waypoints.poses[i].position.z = z

        self.get_logger().info(f"✅ Sent {len(wp)} mission waypoints including infected plant operations.")
        return response



def main():
    rclpy.init()
    node = FullMissionWaypointService()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        node.get_logger().info("🛑 Service stopped.")
    finally:
        node.destroy_node()
        rclpy.shutdown()



if __name__ == "__main__":
    main()

#!/usr/bin/env python3
import time
import math
import rclpy
from rclpy.action import ActionServer
from rclpy.node import Node
from rclpy.callback_groups import ReentrantCallbackGroup
from rclpy.executors import MultiThreadedExecutor

from waypoint_navigation.action import NavToWaypoint
from swift_msgs.msg import SwiftMsgs
from geometry_msgs.msg import PoseArray, Pose
from nav_msgs.msg import Odometry
from error_msg.msg import Error
from tf_transformations import euler_from_quaternion
from collections import deque
import numpy as np
from scipy.signal import iirnotch, lfilter


class WayPointServer(Node):
    def __init__(self):
        super().__init__("waypoint_server")

        # --- State variables ---
        self.current_state = [0.0, 0.0, 0.0, 0.0]
        self.current_state_filtered = [0.0, 0.0, 0.0, 0.0]
        self.desired_state = [0.0, 0.0, 0.0, 0.0]

        # --- PID gains (stable tuned set) ---
        self.Kp = [7.0, 6.0, 12.0, 0.45]
        self.Ki = [0.12, 0.12, 1.5, 0.02]
        self.Kd = [6.0, 8.0, 38.0, 0.008]

        # --- PID states ---
        self.prev_error = [0.0, 0.0, 0.0, 0.0]
        self.error_sum = [0.0, 0.0, 0.0, 0.0]
        self.prev_output = [1500, 1500, 1500, 1500]

        # --- Constants ---
        self.alpha_pose = 0.6
        self.beta_per_axis = [0.92, 0.92, 0.98, 0.9]
        self.integral_limit = 40.0
        self.deadband = 0.10
        self.sample_time = 0.03
        self.last_time = self.get_clock().now().nanoseconds / 1e9

        # --- Drone state ---
        self.diff_x = self.diff_y = self.diff_z = self.diff_yaw = 0.0
        self.cmd = SwiftMsgs()
        self.max_values = [2000, 2000, 2000, 2000]
        self.min_values = [1000, 1000, 1000, 1000]
        self.stable_counter = 0
        self.initial_yaw_set = False
        self.desired_yaw = None
        # --- Kalman Filter for Z (1D altitude estimation) ---
        self.z_kalman = {
            "x": np.array([[0.0], [0.0]]),   # [altitude, vertical_velocity]
            "P": np.eye(2),                  # covariance matrix
            "F": np.array([[1.0, self.sample_time],
                           [0.0, 1.0]]),     # state transition
            "H": np.array([[1.0, 0.0]]),     # measurement model
            "Q": np.array([[1e-3, 0.0],
                           [0.0, 1e-2]]),    # process noise
            "R": np.array([[4e-3]]),         # measurement noise
        }


        # --- Notch Filter Design (for WhyCon Z jitter) ---
        notch_freq = 25.0        # Hz — main noise band
        sampling_rate = 60.0     # WhyCon frame rate
        quality_factor = 4.0     # 5–10 good balance

        self.b_notch, self.a_notch = iirnotch(notch_freq, quality_factor, sampling_rate)
        self.z_filt_state = None
        self.z_window = deque(maxlen=3)  # light moving avg post-notch

        # --- Callback groups ---
        self.action_callback_group = ReentrantCallbackGroup()
        self.timer_callback_group = ReentrantCallbackGroup()
        self.subscriber_callback_group = ReentrantCallbackGroup()

        # --- Publishers ---
        self.command_pub = self.create_publisher(SwiftMsgs, '/drone_command', 10)
        self.pos_error_pub = self.create_publisher(Error, '/pos_error', 10)

        # --- Subscriptions ---
        self.whycon_sub = self.create_subscription(
            PoseArray, "/whycon/poses", self.whycon_callback, 10,
            callback_group=self.subscriber_callback_group
        )
        self.odom_sub = self.create_subscription(
            Odometry, "/rotors/odometry", self.odometry_callback, 10,
            callback_group=self.subscriber_callback_group
        )

        # --- Action server ---
        self._action_server = ActionServer(
            self,
            NavToWaypoint,
            "waypoint_navigation",
            execute_callback=self.execute_callback,
            callback_group=self.action_callback_group
        )

        # --- Control loop ---
        self.control_timer = self.create_timer(self.sample_time, self.pid)
        self.get_logger().info("🧭 Stable Swift Pico Controller started (Notch Filter active)")

        self.arm()

    # ------------------- ARM / DISARM -------------------
    def disarm(self):
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1000
        self.cmd.rc_aux4 = 1000
        self.command_pub.publish(self.cmd)
        self.get_logger().info("Drone disarmed")

    def arm(self):
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1500
        self.cmd.rc_aux4 = 2000
        self.command_pub.publish(self.cmd)
        self.get_logger().info("Drone armed ✅")

    # ------------------- WHYCON CALLBACK -------------------
    def whycon_callback(self, msg):
        if not msg.poses:
            self.get_logger().warn("⚠️ No WhyCon pose detected")
            return

        p = msg.poses[0]
        raw_x, raw_y, raw_z = p.position.x, p.position.y, p.position.z

        # --- Initialize filter state on first frame ---
        if not hasattr(self, "initialized"):
            self.initialized = True
            self.current_state_filtered = [raw_x, raw_y, raw_z, 0.0]
            self.prev_z = raw_z
            self.last_valid_z = raw_z
            self.filtered_dz = 0.0
            return

        # =========================================================
        # 1️⃣ XY smoothing (EMA)
        # =========================================================
        alpha_xy = 0.3
        x_prev, y_prev = self.current_state_filtered[0], self.current_state_filtered[1]
        x_filt = alpha_xy * x_prev + (1 - alpha_xy) * raw_x
        y_filt = alpha_xy * y_prev + (1 - alpha_xy) * raw_y

        # =========================================================
        # 2️⃣ Z filtering (Notch + Moving Average + EMA)
        # =========================================================
        # =========================================================
        # 2️⃣ Z filtering (Notch + Kalman Filter + EMA post-filter)
        # =========================================================
        if self.z_filt_state is None:
            self.z_filt_state = np.zeros(max(len(self.a_notch), len(self.b_notch)) - 1)
            z_notch = raw_z
        else:
            z_notch, self.z_filt_state = lfilter(
                self.b_notch, self.a_notch, [raw_z], zi=self.z_filt_state
            )
            z_notch = z_notch[0]

        # Kalman Filter for Z (predict + update)
        dt = self.sample_time
        F = np.array([[1.0, dt], [0.0, 1.0]])
        H = self.z_kalman["H"]
        Q = self.z_kalman["Q"]
        R = self.z_kalman["R"]

        # --- Predict ---
        x_pred = F @ self.z_kalman["x"]
        P_pred = F @ self.z_kalman["P"] @ F.T + Q

        # --- Update ---
        z_meas = np.array([[z_notch]])
        y = z_meas - (H @ x_pred)
        S = H @ P_pred @ H.T + R
        K = P_pred @ H.T @ np.linalg.inv(S)
        x_new = x_pred + K @ y
        P_new = (np.eye(2) - K @ H) @ P_pred

        # Store updated state
        self.z_kalman["x"], self.z_kalman["P"] = x_new, P_new
        z_kalman = float(x_new[0])  # altitude
        dz_kalman = float(x_new[1]) # vertical velocity

        # --- Post smoothing ---
        alpha_z = 0.35
        z_prev = self.current_state_filtered[2]
        z_filt = alpha_z * z_kalman + (1 - alpha_z) * z_prev

        # Reject abnormal jumps
        if abs(z_filt - self.last_valid_z) > 1.0:
            return
        self.last_valid_z = z_filt

        self.filtered_dz = 0.85 * getattr(self, "filtered_dz", 0.0) + 0.15 * dz_kalman


        # =========================================================
        # 3️⃣ Orientation (yaw)
        # =========================================================
        q = p.orientation
        _, _, yaw = euler_from_quaternion([q.x, q.y, q.z, q.w])
        prev_yaw = self.current_state_filtered[3]
        yaw = math.atan2(
            0.8 * math.sin(prev_yaw) + 0.2 * math.sin(yaw),
            0.8 * math.cos(prev_yaw) + 0.2 * math.cos(yaw)
        )

        # =========================================================
        # 4️⃣ Update filtered state
        # =========================================================
        self.current_state_filtered = [x_filt, y_filt, z_filt, yaw]
        self.current_state = self.current_state_filtered.copy()

        # =========================================================
        # 5️⃣ Smooth vertical velocity estimate
        # =========================================================
        raw_dz = z_filt - self.prev_z
        raw_dz = max(min(raw_dz, 2.0), -2.0)
        self.filtered_dz = 0.9 * self.filtered_dz + 0.1 * raw_dz
        self.prev_z = z_filt

        # Optional debug every few seconds
        if int(time.time()) % 5 == 0:
            self.get_logger().info(f"📡 WhyCon filtered → x:{x_filt:.2f}, y:{y_filt:.2f}, z:{z_filt:.2f}")

    # ------------------- ODOM CALLBACK -------------------
    def odometry_callback(self, msg: Odometry):
        q = msg.pose.pose.orientation
        _, _, yaw = euler_from_quaternion([q.x, q.y, q.z, q.w])
        self.current_yaw = yaw
        if not self.initial_yaw_set:
            self.desired_yaw = yaw
            self.initial_yaw_set = True
            self.get_logger().info(f"Initial Yaw Baseline set to: {math.degrees(yaw):.2f}°")

    # ------------------- ACTION SERVER -------------------
    def execute_callback(self, goal_handle):
        self.get_logger().info("Executing goal...")
        goal_pose = goal_handle.request.waypoint
        self.desired_state[0] = goal_pose.position.x
        self.desired_state[1] = goal_pose.position.y
        self.desired_state[2] = goal_pose.position.z
        q = goal_pose.orientation
        _, _, self.desired_state[3] = euler_from_quaternion([q.x, q.y, q.z, q.w])
        self.get_logger().info(f"New Waypoint Set: {self.desired_state}")

        feedback_msg = NavToWaypoint.Feedback()
        result = NavToWaypoint.Result()
        start_time = self.get_clock().now().nanoseconds / 1e9
        hover_start_time = None
        max_hover_time = 0

        while rclpy.ok():
            if goal_handle.is_cancel_requested:
                goal_handle.canceled()
                self.get_logger().info("Goal canceled by client.")
                return result

            try:
                feedback_msg.current_position.x = self.current_state[0]
                feedback_msg.current_position.y = self.current_state[1]
                feedback_msg.current_position.z = self.current_state[2]
                goal_handle.publish_feedback(feedback_msg)
            except Exception:
                pass

            in_sphere = self.is_drone_in_sphere(self.current_state, self.desired_state, 0.4)
            if in_sphere:
                if hover_start_time is None:
                    hover_start_time = self.get_clock().now().nanoseconds / 1e9
                    self.get_logger().info("🟢 Drone entered hover sphere.")
                else:
                    hover_duration = (self.get_clock().now().nanoseconds / 1e9) - hover_start_time
                    if hover_duration > max_hover_time:
                        max_hover_time = hover_duration
                    self.get_logger().info(f"Hovering... {hover_duration:.2f}s inside sphere.")
                    if hover_duration >= 3.0:
                        total_time = (self.get_clock().now().nanoseconds / 1e9) - start_time
                        result.hover_time = int(hover_duration)
                        self.get_logger().info(f"✅ Hover stable for {hover_duration:.2f}s (Total: {total_time:.2f}s).")
                        goal_handle.succeed()
                        return result
            else:
                hover_start_time = None

            time.sleep(0.05)
        return result

    # ------------------- PID LOOP -------------------
    def pid(self):
        now = self.get_clock().now().nanoseconds / 1e9
        dt = max(now - self.last_time, 1e-6)
        self.last_time = now

        def safe_num(x, default=0.0):
            try:
                if x is None or not math.isfinite(x):
                    return default
                return float(x)
            except Exception:
                return default

        def compute_pid(axis, desired, current, prev_err, err_sum, diff_prev):
            prev_err = safe_num(prev_err)
            diff_prev = safe_num(diff_prev)
            error = desired - current
            if axis == 3:
                error = math.atan2(math.sin(error), math.cos(error))
            if axis == 2 and abs(error) < 0.05:
                error = 0.0
            elif axis != 2 and abs(error) < self.deadband:
                error = 0.0
            beta_effective = self.beta_per_axis[axis]
            diff_raw = (error - prev_err) / dt if dt > 0 else 0.0
            diff_filtered = beta_effective * diff_prev + (1.0 - beta_effective) * diff_raw
            if abs(error) < 1.0:
                err_sum += error * dt
            err_sum = max(-self.integral_limit, min(self.integral_limit, err_sum))
            output = self.Kp[axis] * error + self.Ki[axis] * err_sum + self.Kd[axis] * diff_filtered
            return output, error, err_sum, diff_filtered

        # --- PID for axes ---
        out_x, ex, self.error_sum[0], self.diff_x = compute_pid(
            0, self.desired_state[0], self.current_state[0],
            self.prev_error[0], self.error_sum[0], getattr(self, "diff_x", 0.0)
        )
        out_y, ey, self.error_sum[1], self.diff_y = compute_pid(
            1, self.current_state[1],self.desired_state[1],
            self.prev_error[1], self.error_sum[1], getattr(self, "diff_y", 0.0)
        )

        # --- Yaw ---
        ez_yaw = 0.0
        rc_yaw = 1500
        if self.desired_yaw is not None and hasattr(self, "current_yaw"):
            out_yaw, ez_yaw, self.error_sum[3], self.diff_yaw = compute_pid(
                3, self.desired_yaw, self.current_yaw,
                self.prev_error[3], self.error_sum[3], getattr(self, "diff_yaw", 0.0)
            )
            rc_yaw = 1500 + out_yaw

        # --- Altitude PID ---
        z_target = self.desired_state[2]-1.4
        z_err = z_target - self.current_state[2]
        if abs(z_err) < 0.05:
            z_err = 0.0
        # Integrator control
        if abs(z_err) < 0.5:
            self.error_sum[2] += z_err * dt
        elif abs(z_err) > 1.0:
            self.error_sum[2] *= 0.7  # anti-windup for large deviation
        self.error_sum[2] = max(-20.0, min(20.0, self.error_sum[2]))

        self.prev_z_err = getattr(self, "prev_z_err", 0.0)
        raw_dz = (z_err - self.prev_z_err) / dt
        self.prev_z_err = z_err
        self.filtered_dz = 0.85 * getattr(self, "filtered_dz", 0.0) + 0.25 * raw_dz

        if abs(self.filtered_dz) < 0.06:
            self.filtered_dz = 0.0

        Kp_z, Ki_z, Kd_z = self.Kp[2], self.Ki[2], self.Kd[2]
        out_z = Kp_z * z_err + Ki_z * self.error_sum[2] + Kd_z * self.filtered_dz
        self.prev_throttle_out = getattr(self, "prev_throttle_out", 1500)
        smooth_out_z = 0.9 * self.prev_throttle_out + 0.1 * (1500 - out_z)
        self.prev_throttle_out = smooth_out_z

        # --- Command outputs ---
        rc_thr = int(max(self.min_values[2], min(self.max_values[2], smooth_out_z)))
        rc_pitch = int(self.alpha_pose * self.prev_output[0] + (1 - self.alpha_pose) * (1500 + out_x))
        rc_roll = int(self.alpha_pose * self.prev_output[1] + (1 - self.alpha_pose) * (1500 - out_y))
        rc_yaw = int(self.alpha_pose * self.prev_output[3] + (1 - self.alpha_pose) * rc_yaw)

        self.cmd.rc_throttle, self.cmd.rc_pitch, self.cmd.rc_roll, self.cmd.rc_yaw = rc_thr, rc_pitch, rc_roll, rc_yaw
        self.command_pub.publish(self.cmd)

        # --- Stability detection ---
        if abs(z_err) < 0.4 and abs(self.filtered_dz) < 0.04:
            self.stable_counter += 1
        else:
            self.stable_counter = 0
        if self.stable_counter > int(3.0 / max(self.sample_time, 0.01)):
            self.get_logger().info("✅ Altitude stable at waypoint (3s)")

        self.prev_error = [ex, ey, z_err, ez_yaw]
        self.prev_output = [rc_pitch, rc_roll, rc_thr, rc_yaw]

    # ------------------- UTILITY -------------------
    def is_drone_in_sphere(self, drone_pos, goal_pos, radius):
        dx, dy, dz = drone_pos[0] - goal_pos[0], drone_pos[1] - goal_pos[1], drone_pos[2] - goal_pos[2]
        return (dx * dx + dy * dy + dz * dz) <= (radius * radius)


def main(args=None):
    rclpy.init(args=args)
    node = WayPointServer()
    executor = MultiThreadedExecutor(num_threads=4)
    executor.add_node(node)
    try:
        executor.spin()
    except KeyboardInterrupt:
        node.get_logger().info("KeyboardInterrupt, shutting down.")
    finally:
        executor.shutdown()
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()

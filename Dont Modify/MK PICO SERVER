#!/usr/bin/env python3
import time
import math
import rclpy
from rclpy.action import ActionServer
from rclpy.node import Node
from rclpy.callback_groups import ReentrantCallbackGroup
from rclpy.executors import MultiThreadedExecutor

# Action, message, and service types
from waypoint_navigation.action import NavToWaypoint
from swift_msgs.msg import SwiftMsgs
from geometry_msgs.msg import Pose, Vector3
from nav_msgs.msg import Odometry
from controller_msg.msg import PIDTune
from tf_transformations import euler_from_quaternion


# ------------------------ SwiftPID (full PID logic) ------------------------ #
class SwiftPID:
    def __init__(self, node: Node):
        self.node = node

        # --- PID constants (index mapping: 0 -> X/pitch, 1 -> Y/roll, 2 -> Z/throttle, 3 -> yaw)
        self.Kp = [10.0, 8.0, 22.0, 0.5]
        self.Ki = [0.30, 0.35, 5.0, 0.05]
        self.Kd = [7.5, 12.0, 40.0, 0.01]  # keep original requested values

        # --- Internal state ---
        self.prev_error = [0.0, 0.0, 0.0, 0.0]
        self.error_sum = [0.0, 0.0, 0.0, 0.0]
        self.prev_output = [1500, 1500, 1500, 1500]

        # --- Derivative filters ---
        self.diff_x = 0.0
        self.diff_y = 0.0
        self.diff_z = 0.0
        self.diff_yaw = 0.0

        # RC command message placeholder
        self.cmd = SwiftMsgs()
        self.reset_rc()

        # RC limits
        self.max_values = [2000, 2000, 2000, 2000]
        self.min_values = [1000, 1000, 1000, 1000]

        # Timing & smoothing
        self.sample_time = 0.03
        self.alpha = 0.35
        self.beta = 0.92   # baseline; Z-axis uses 0.98 inside compute
        self.integral_limit = 60.0
        self.deadband = 0.20

        # Stability detection
        self.stable_counter = 0

        # yaw baseline
        self.desired_yaw = None
        self.initial_yaw_set = False
        self.current_yaw = 0.0

        # publishers set by server
        self.command_pub = None
        self.pos_error_pub = None

    def reset_rc(self):
        # try canonical field names, fallback handled in publishing
        try:
            self.cmd.rc_roll = 1500
            self.cmd.rc_pitch = 1500
            self.cmd.rc_throttle = 1500
            self.cmd.rc_yaw = 1500
            self.cmd.rc_aux4 = 1500
        except Exception:
            # Some message definitions use different casing; safe defaults later
            pass

    def safe_num(self, x, default=0.0):
        try:
            if x is None:
                return default
            if not math.isfinite(x):
                return default
            return float(x)
        except Exception:
            return default

    # PID tune handlers (node will register subscriptions to these)
    def altitude_set_pid(self, msg: PIDTune):
        # original code used msg.kp, msg.ki, msg.kd per topic; adapt if message fields differ
        # if PIDTune contains kp,ki,kd use those else attempt throttle-specific fields
        kp = getattr(msg, "kp", None)
        ki = getattr(msg, "ki", None)
        kd = getattr(msg, "kd", None)
        if kp is not None:
            self.Kp[2] = kp
            self.Ki[2] = (ki / 250.0) if ki is not None else self.Ki[2]
            self.Kd[2] = kd if kd is not None else self.Kd[2]
        else:
            # try throttle-specific names
            self.Kp[2] = getattr(msg, "kp_throttle", self.Kp[2])
            self.Ki[2] = getattr(msg, "ki_throttle", self.Ki[2])
            self.Kd[2] = getattr(msg, "kd_throttle", self.Kd[2])
        self.node.get_logger().info(f"Updated Altitude PID: Kp={self.Kp[2]}, Ki={self.Ki[2]}, Kd={self.Kd[2]}")

    def pitch_set_pid(self, msg: PIDTune):
        kp = getattr(msg, "kp", None)
        ki = getattr(msg, "ki", None)
        kd = getattr(msg, "kd", None)
        if kp is not None:
            self.Kp[0] = kp
            self.Ki[0] = (ki / 250.0) if ki is not None else self.Ki[0]
            self.Kd[0] = kd if kd is not None else self.Kd[0]
        else:
            self.Kp[0] = getattr(msg, "kp_pitch", self.Kp[0])
            self.Ki[0] = getattr(msg, "ki_pitch", self.Ki[0])
            self.Kd[0] = getattr(msg, "kd_pitch", self.Kd[0])
        self.node.get_logger().info(f"Updated Pitch PID: Kp={self.Kp[0]}, Ki={self.Ki[0]}, Kd={self.Kd[0]}")

    def roll_set_pid(self, msg: PIDTune):
        kp = getattr(msg, "kp", None)
        ki = getattr(msg, "ki", None)
        kd = getattr(msg, "kd", None)
        if kp is not None:
            self.Kp[1] = kp
            self.Ki[1] = (ki / 250.0) if ki is not None else self.Ki[1]
            self.Kd[1] = kd if kd is not None else self.Kd[1]
        else:
            self.Kp[1] = getattr(msg, "kp_roll", self.Kp[1])
            self.Ki[1] = getattr(msg, "ki_roll", self.Ki[1])
            self.Kd[1] = getattr(msg, "kd_roll", self.Kd[1])
        self.node.get_logger().info(f"Updated Roll PID: Kp={self.Kp[1]}, Ki={self.Ki[1]}, Kd={self.Kd[1]}")

    def odometry_update(self, odom_msg: Odometry):
        orientation_q = odom_msg.pose.pose.orientation
        orientation_list = [orientation_q.x, orientation_q.y, orientation_q.z, orientation_q.w]
        (roll, pitch, yaw) = euler_from_quaternion(orientation_list)
        self.current_yaw = yaw
        if not self.initial_yaw_set:
            self.desired_yaw = self.current_yaw
            self.initial_yaw_set = True
            self.node.get_logger().info(f"Initial Yaw Baseline set to: {math.degrees(self.desired_yaw):.2f}°")

    # compute PID for a single axis (mirrors original compute_pid)
    def compute_pid_axis(self, axis, desired, current, prev_err, err_sum, diff_prev, dt):
        prev_err = self.safe_num(prev_err, 0.0)
        diff_prev = self.safe_num(diff_prev, 0.0)

        error = desired - current

        # yaw wrap-around
        if axis == 3:
            error = math.atan2(math.sin(error), math.cos(error))

        # deadbands
        if axis == 2 and abs(error) < 0.05:
            error = 0.0
        elif abs(error) < self.deadband:
            error = 0.0

        # targeted derivative filter
        beta_effective = self.beta
        if axis == 2:
            beta_effective = 0.98

        diff_raw = (error - prev_err) / dt if dt > 0 else 0.0
        diff_filtered = beta_effective * diff_prev + (1.0 - beta_effective) * diff_raw

        # integral handling (no integral for Z if high motion)
        if axis != 2:
            if abs(error) > self.deadband:
                err_sum += error * dt

        # clamp integral
        if not math.isfinite(err_sum):
            err_sum = 0.0
        err_sum = max(-self.integral_limit, min(self.integral_limit, err_sum))

        # PID output
        output = (self.Kp[axis] * error +
                  self.Ki[axis] * err_sum +
                  self.Kd[axis] * diff_filtered)
        return float(output), float(error), float(err_sum), float(diff_filtered)

    # top-level update, returns SwiftMsgs command and axis errors
    def update_and_get_cmd(self, desired_state, current_state, dt):
        # compute pitch (X)
        out_x, ex, self.error_sum[0], self.diff_x = self.compute_pid_axis(
            0, desired_state[0], current_state[0],
            self.prev_error[0], self.error_sum[0], getattr(self, "diff_x", 0.0), dt
        )

        # compute roll (Y)
        out_y, ey, self.error_sum[1], self.diff_y = self.compute_pid_axis(
            1, desired_state[1], current_state[1],
            self.prev_error[1], self.error_sum[1], getattr(self, "diff_y", 0.0), dt
        )

        # yaw
        ez_yaw = 0.0
        rc_yaw = 1500
        if self.desired_yaw is not None:
            out_yaw, ez_yaw, self.error_sum[3], self.diff_yaw = self.compute_pid_axis(
                3, self.desired_yaw, self.current_yaw,
                self.prev_error[3], self.error_sum[3], getattr(self, "diff_yaw", 0.0), dt
            )
            rc_yaw = 1500 + out_yaw

        # Throttle adaptive handling (Z)
        out_z_tmp, ez_tmp, _, diff_z_tmp = self.compute_pid_axis(
            2, desired_state[2], current_state[2],
            self.prev_error[2], self.error_sum[2], getattr(self, "diff_z", 0.0), dt
        )
        self.diff_z = self.safe_num(diff_z_tmp, 0.0)
        ez = self.safe_num(ez_tmp, 0.0)

        horiz_err = math.hypot(desired_state[0] - current_state[0],
                               desired_state[1] - current_state[1])
        horizontal_motion_threshold = 0.15
        pitch_activity_threshold = 8.0
        pitch_activity = abs(out_x)

        throttle_integrate = not (horiz_err > horizontal_motion_threshold or pitch_activity > pitch_activity_threshold)

        thr_err_sum = self.safe_num(self.error_sum[2], 0.0)

        if throttle_integrate and abs(ez) > 0.02:
            thr_err_sum += ez * dt

        thr_err_sum = max(-self.integral_limit, min(self.integral_limit, thr_err_sum))
        self.error_sum[2] = thr_err_sum

        out_z, ez, self.error_sum[2], self.diff_z = self.compute_pid_axis(
            2, desired_state[2], current_state[2],
            self.prev_error[2], self.error_sum[2], getattr(self, "diff_z", 0.0), dt
        )

        # coupling compensation
        k_couple = 0.08
        coupling_comp = k_couple * out_x
        out_z -= coupling_comp

        # RC mapping
        rc_thr = 1500 - out_z
        rc_pitch = 1500 + out_x
        rc_roll = 1500 - out_y

        # smoothing
        alpha_throttle = 0.45
        rc_thr = int(alpha_throttle * self.prev_output[2] + (1.0 - alpha_throttle) * rc_thr)
        rc_pitch = int(self.alpha * self.prev_output[0] + (1.0 - self.alpha) * rc_pitch)
        rc_roll = int(self.alpha * self.prev_output[1] + (1.0 - self.alpha) * rc_roll)
        rc_yaw = int(self.alpha * self.prev_output[3] + (1.0 - self.alpha) * rc_yaw)

        # clamp
        rc_thr = max(self.min_values[2], min(self.max_values[2], rc_thr))
        rc_pitch = max(self.min_values[0], min(self.max_values[0], rc_pitch))
        rc_roll = max(self.min_values[1], min(self.max_values[1], rc_roll))
        rc_yaw = max(self.min_values[3], min(self.max_values[3], rc_yaw))

        # populate command
        try:
            self.cmd.rc_throttle = rc_thr
            self.cmd.rc_pitch = rc_pitch
            self.cmd.rc_roll = rc_roll
            self.cmd.rc_yaw = rc_yaw
            # preserve aux if present
            try:
                self.cmd.rc_aux4 = getattr(self.cmd, "rc_aux4", 1500)
            except Exception:
                pass
        except Exception:
            # fallback field names
            self.cmd.rcThrottle = rc_thr
            self.cmd.rcPitch = rc_pitch
            self.cmd.rcRoll = rc_roll
            self.cmd.rcYaw = rc_yaw

        # save prev outputs and prev_error
        self.prev_output = [rc_pitch, rc_roll, rc_thr, rc_yaw]
        self.prev_error = [ex, ey, ez, ez_yaw]

        return self.cmd, (ex, ey, ez)


# ------------------------ WayPointServer (keeps your structure) ------------------------ #
class WayPointServer(Node):
    def __init__(self):
        super().__init__("waypoint_server")

        self.action_callback_group = ReentrantCallbackGroup()
        self.timer_callback_group = ReentrantCallbackGroup()
        self.subscriber_callback_group = ReentrantCallbackGroup()

        # Core drone state variables
        # curr_state: [x, y, z, yaw]
        self.curr_state = [0.0, 0.0, 0.0, 0.0]
        # desired_state: [x, y, z, yaw]
        self.desired_state = [0.0, 0.0, 0.0, 0.0]

        # Time for derivative calculation
        self.last_time = self.get_clock().now().nanoseconds / 1e9

        # Topic -> command publisher
        self.command_pub = self.create_publisher(SwiftMsgs, "/drone_command", 10)

        # PIDTune listener (we forward to SwiftPID handlers)
        self.swift_pid = SwiftPID(self)

        # Subscribe tuning topics
        self.create_subscription(PIDTune, "/pid_tuning", self.swift_pid.altitude_set_pid, 10, callback_group=self.subscriber_callback_group)
        self.create_subscription(PIDTune, "/pid_tuning", self.swift_pid.pitch_set_pid, 10, callback_group=self.subscriber_callback_group)
        self.create_subscription(PIDTune, "/pid_tuning", self.swift_pid.roll_set_pid, 10, callback_group=self.subscriber_callback_group)

        # Subscribers
        # odom (for position + yaw)
        self.odom_sub = self.create_subscription(Odometry, "/odom", self.odom_callback, 10, callback_group=self.subscriber_callback_group)

        # Action server
        self._action_server = ActionServer(
            self,
            NavToWaypoint,
            "waypoint_navigation",
            execute_callback=self.execute_callback,
            callback_group=self.action_callback_group,
        )

        # Control loop timer (50Hz)
        self.control_timer = self.create_timer(0.02, self.control_loop_callback, callback_group=self.timer_callback_group)

        # Feedback timer (0.2s)
        self.feedback_timer = self.create_timer(0.2, self.feedback_publish_callback, callback_group=self.timer_callback_group)

        # Internal action/goal state
        self.current_goal_handle = None
        self.goal_active = False
        self.point_in_sphere_start_time = None
        self.time_inside_sphere = 0.0
        self.max_time_inside_sphere = 0.0

        # mission time
        self.mission_start_time = None

        # ensure SwiftPID publishes to same publisher (if needed)
        self.swift_pid.command_pub = self.command_pub

        self.get_logger().info("Waypoint Server has started.")

    # ------------------- SUBSCRIBER CALLBACKS ------------------- #
    def odom_callback(self, msg: Odometry):
        """Update current drone state from odometry and forward yaw to PID."""
        self.curr_state[0] = msg.pose.pose.position.x
        self.curr_state[1] = msg.pose.pose.position.y
        self.curr_state[2] = msg.pose.pose.position.z

        orientation_q = msg.pose.pose.orientation
        _, _, yaw = euler_from_quaternion([orientation_q.x, orientation_q.y, orientation_q.z, orientation_q.w])
        self.curr_state[3] = yaw

        # forward odom to pid (for yaw baseline)
        self.swift_pid.odometry_update(msg)

    def pid_callback(self, msg: PIDTune):
        # this method kept for compatibility if a different pid_tuning topic is used
        # we forward to swift_pid handlers
        self.swift_pid.altitude_set_pid(msg)
        self.swift_pid.pitch_set_pid(msg)
        self.swift_pid.roll_set_pid(msg)

    # ------------------- ACTION SERVER CALLBACK ------------------- #
    def execute_callback(self, goal_handle):
        """Handle received waypoint goal from client."""
        # Accept both NavToWaypoint.goal with 'target_position' (Point) or 'waypoint' (Pose)
        try:
            target = goal_handle.request.target_position
            desired = [target.x, target.y, target.z]
        except Exception:
            try:
                pose = goal_handle.request.waypoint
                desired = [pose.position.x, pose.position.y, pose.position.z]
            except Exception:
                self.get_logger().error("Goal format not recognized.")
                goal_handle.abort()
                return NavToWaypoint.Result()

        # Set mission start time
        if self.mission_start_time is None:
            self.mission_start_time = time.time()

        # Set desired state (only x,y,z)
        self.desired_state = [desired[0], desired[1], desired[2], self.desired_state[3]]

        self.get_logger().info(f"🚀 New waypoint goal: {self.desired_state}")

        feedback_msg = NavToWaypoint.Feedback()
        result = NavToWaypoint.Result()

        start_time = self.get_clock().now().nanoseconds / 1e9
        self.max_time_inside_sphere = 0.0
        self.time_inside_sphere = 0.0

        # Reset PID integrators/prev errors for new goal
        self.swift_pid.prev_error = [0.0, 0.0, 0.0, 0.0]
        self.swift_pid.error_sum = [0.0, 0.0, 0.0, 0.0]

        self.current_goal_handle = goal_handle
        self.goal_active = True
        self.point_in_sphere_start_time = None
        self.time_inside_sphere = 0.0

        # wait-check loop (publishes feedback via feedback_timer)
        while rclpy.ok():
            # provide immediate feedback
            feedback_msg.current_waypoint.pose.position.x = self.curr_state[0]
            feedback_msg.current_waypoint.pose.position.y = self.curr_state[1]
            feedback_msg.current_waypoint.pose.position.z = self.curr_state[2]
            feedback_msg.current_waypoint.header.stamp.sec = int(self.max_time_inside_sphere)
            goal_handle.publish_feedback(feedback_msg)

            # compute euclidean error
            err = math.sqrt(
                (self.desired_state[0] - self.curr_state[0])**2 +
                (self.desired_state[1] - self.curr_state[1])**2 +
                (self.desired_state[2] - self.curr_state[2])**2
            )

            # thresholds
            enter_threshold = 0.4
            exit_threshold = 0.55

            if err <= enter_threshold:
                if self.point_in_sphere_start_time is None:
                    self.point_in_sphere_start_time = time.time()
                else:
                    self.time_inside_sphere = time.time() - self.point_in_sphere_start_time

                if self.time_inside_sphere >= 3.0:
                    self.get_logger().info("✅ Waypoint reached and hovered for 3s.")
                    result.hov_time = self.get_clock().now().nanoseconds / 1e9 - start_time
                    goal_handle.succeed()
                    # cleanup
                    self.goal_active = False
                    self.current_goal_handle = None
                    return result
            else:
                # if outside exit threshold, reset hold
                if err > exit_threshold:
                    if self.point_in_sphere_start_time is not None:
                        self.point_in_sphere_start_time = None
                        self.time_inside_sphere = 0.0
                        self.get_logger().warn("⚠️ Drift detected — Hold timer reset")

            # preemption/cancel checks
            if not goal_handle.is_active:
                self.get_logger().info("Goal aborted or preempted.")
                return NavToWaypoint.Result()

            if goal_handle.is_cancel_requested:
                goal_handle.canceled()
                self.get_logger().info("Goal canceled.")
                return NavToWaypoint.Result()

            time.sleep(0.1)

        # If loop exits unexpectedly
        goal_handle.abort()
        self.goal_active = False
        self.current_goal_handle = None
        return NavToWaypoint.Result()

    # ------------------- CONTROL LOOP ------------------- #
    def control_loop_callback(self):
        """Main PID control loop (50Hz) - calls SwiftPID and publishes commands."""
        # dtime
        current_time = self.get_clock().now().nanoseconds / 1e9
        dtime = current_time - self.last_time
        self.last_time = current_time

        if dtime <= 0.0:
            return

        # desired_state contains [x,y,z,yaw]; current in self.curr_state
        desired_xyz = [self.desired_state[0], self.desired_state[1], self.desired_state[2]]
        current_xyz = [self.curr_state[0], self.curr_state[1], self.curr_state[2]]

        # get command from SwiftPID
        cmd_msg, errors = self.swift_pid.update_and_get_cmd(desired_xyz, current_xyz, dtime)

        # publish command
        try:
            # use same field names as your original server expected
            self.command_pub.publish(cmd_msg)
        except Exception:
            # best-effort fallback for message field differences
            try:
                cmd_msg.header = getattr(cmd_msg, 'header', None)
            except Exception:
                pass
            self.command_pub.publish(cmd_msg)

        # also publish pos_error if you have pos_error topic (optional)
        # create an Error message only if publisher exists on desired name
        # (user originally did not create pos_error publisher in this variant, so skipping)

    # ------------------- FEEDBACK TIMER (0.2s) ------------------- #
    def feedback_publish_callback(self):
        # publish action feedback if active
        if self.current_goal_handle is not None and self.goal_active and self.current_goal_handle.is_active:
            feedback = NavToWaypoint.Feedback()
            feedback.current_waypoint.pose.position.x = self.curr_state[0]
            feedback.current_waypoint.pose.position.y = self.curr_state[1]
            feedback.current_waypoint.pose.position.z = self.curr_state[2]
            self.current_goal_handle.publish_feedback(feedback)

        # mission time warning
        if self.mission_start_time is not None:
            elapsed = time.time() - self.mission_start_time
            if elapsed > 180.0:
                self.get_logger().warn("⚠️ Mission exceeded 180 seconds limit!")

    # ------------------- HELPERS ------------------- #
    def is_drone_in_sphere(self, drone_pos, goal_pos, radius):
        dx = drone_pos[0] - goal_pos[0]
        dy = drone_pos[1] - goal_pos[1]
        dz = drone_pos[2] - goal_pos[2]
        return (dx * dx + dy * dy + dz * dz) <= (radius * radius)


def main(args=None):
    rclpy.init(args=args)
    node = WayPointServer()

    # Use MultiThreadedExecutor to handle all callbacks concurrently
    executor = MultiThreadedExecutor(num_threads=4)
    executor.add_node(node)

    try:
        executor.spin()
    except KeyboardInterrupt:
        node.get_logger().info("KeyboardInterrupt, shutting down.")
    finally:
        executor.shutdown()
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
import rclpy
from rclpy.node import Node
from rclpy.action import ActionClient
from waypoint_navigation.action import NavToWaypoint
from waypoint_navigation.srv import GetWaypoints
from geometry_msgs.msg import Vector3
import time


class PicoWaypointClient(Node):
    def __init__(self):
        super().__init__('pico_waypoint_client')

        # Action + Service clients
        self.action_client = ActionClient(self, NavToWaypoint, 'waypoint_navigation')
        self.service_client = self.create_client(GetWaypoints, 'waypoints')

        # Waypoint request
        self.req = GetWaypoints.Request()
        self.req.get_waypoints = True

        # Storage for waypoint list
        self.goals = []
        self.goal_index = 0

        # Feedback publisher
        self.desired_pub = self.create_publisher(Vector3, '/desired_state', 10)

        # Wait for service
        while not self.service_client.wait_for_service(timeout_sec=1.0):
            self.get_logger().info("⏳ Waiting for waypoint service...")

    # ---------------------------------------------------------------
    def request_waypoints(self):
        self.get_logger().info("📡 Requesting mission waypoints...")
        future = self.service_client.call_async(self.req)
        rclpy.spin_until_future_complete(self, future)
        resp = future.result()

        if not resp or not resp.waypoints.poses:
            self.get_logger().error("❌ Failed to get waypoint list.")
            return

        # Load all waypoints
        for pose in resp.waypoints.poses:
            self.goals.append([
                pose.position.x,
                pose.position.y,
                pose.position.z
            ])

        self.get_logger().info(f"✅ Received {len(self.goals)} waypoints:")
        for i, g in enumerate(self.goals):
            self.get_logger().info(f"   {i+1}: {g}")

        # Start sending mission
        if self.goals:
            self.send_goal(self.goals[0])

    # ---------------------------------------------------------------
    def send_goal(self, waypoint):
        goal_msg = NavToWaypoint.Goal()
        goal_msg.waypoint.position.x = waypoint[0]
        goal_msg.waypoint.position.y = waypoint[1]
        goal_msg.waypoint.position.z = waypoint[2]

        self.get_logger().info(f"🚀 Sending waypoint: {waypoint}")

        self.action_client.wait_for_server()

        future = self.action_client.send_goal_async(
            goal_msg,
            feedback_callback=self.feedback_callback
        )
        future.add_done_callback(self.goal_response_callback)

    # ---------------------------------------------------------------
    def goal_response_callback(self, future):
        handle = future.result()
        if not handle.accepted:
            self.get_logger().warn("❌ Waypoint goal rejected.")
            return

        self.get_logger().info("✅ Waypoint goal accepted.")
        result_future = handle.get_result_async()
        result_future.add_done_callback(self.result_callback)

    # ---------------------------------------------------------------
    def feedback_callback(self, feedback_msg):
        """
        pico_server publishes feedback.current_position.pose.position.{x,y,z}
        """
        pose = feedback_msg.feedback.current_position.pose.position

        fb = Vector3(x=pose.x, y=pose.y, z=pose.z)
        self.desired_pub.publish(fb)

        self.get_logger().info(
            f"📡 Feedback → X={pose.x:.2f}, Y={pose.y:.2f}, Z={pose.z:.2f}"
        )

    # ---------------------------------------------------------------
    def result_callback(self, future):
        # pico_server returns an empty NavToWaypoint.Result()
        self.get_logger().info("🏁 Waypoint reached (server confirmed).")

        # Move to next waypoint
        self.goal_index += 1

        if self.goal_index < len(self.goals):
            time.sleep(0.2)
            self.send_goal(self.goals[self.goal_index])
        else:
            self.get_logger().info("🎯 FULL MISSION COMPLETED!")
            self.shutdown()

    # ---------------------------------------------------------------
    def shutdown(self):
        self.get_logger().info("🛑 Shutting down pico waypoint client.")
        self.destroy_node()
        rclpy.shutdown()


def main(args=None):
    rclpy.init(args=args)
    node = PicoWaypointClient()
    node.request_waypoints()

    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        node.shutdown()
    finally:
        rclpy.shutdown()


if __name__ == '__main__':
    main()

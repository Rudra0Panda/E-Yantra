INFECTED_PERCENTAGE_THRESHOLD = 1.0  # percent
FIRST_FRAME_TIMEOUT = 12.0  # seconds to wait for first frame
SPHERE_RADIUS = 0.4
HOVER_DURATION = 2.0
SPRAY_DURATION = 2.0
TASK1A_OUTPUT = os.path.expanduser("~/pico_ws/infected_plants.txt")


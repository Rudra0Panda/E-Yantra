#!/usr/bin/env python3
import time
import math
import rclpy
from rclpy.node import Node
from rclpy.action import ActionServer
from rclpy.callback_groups import ReentrantCallbackGroup
from rclpy.executors import MultiThreadedExecutor

from waypoint_navigation.action import NavToWaypoint
from swift_msgs.msg import SwiftMsgs
from geometry_msgs.msg import PoseArray
from nav_msgs.msg import Odometry
from std_msgs.msg import String
from sensor_msgs.msg import Image
from cv_bridge import CvBridge
from tf_transformations import euler_from_quaternion

import cv2
import numpy as np

# ---------------------------------------------------------------
HSV_YELLOW_RANGE = (np.array([20, 50, 100]), np.array([35, 255, 255]))  # yellow infection range
PLANT_BLOCK_Z_THRESHOLD = 31.5  # altitude threshold for plant area
# ---------------------------------------------------------------


class WayPointServerFinal(Node):
    def __init__(self):
        super().__init__("waypoint_server_task2b_final_v2")

        # --- Drone state ---
        self.cmd = SwiftMsgs()
        self.current_state = [0.0, 0.0, 0.0, 0.0]  # [x, y, z, yaw]
        self.desired_state = [0.0, 0.0, 29.22, 0.0]
        self.current_yaw = 0.0
        self.desired_yaw = None
        self.initial_yaw_set = False

        # --- PID parameters ---
        self.Kp = [10, 8, 16.0, 0.5]
        self.Ki = [0.30, 0.35, 1.0, 0.05]
        self.Kd = [11, 14, 32.0, 0.01]

        self.sample_time = 0.03
        self.deadband = 0.15
        self.deadband_z = 0.05
        self.integral_limit = 40.0
        self.alpha_cmd = 0.35
        self.alpha_thr = 0.65
        self.beta = 0.92
        self.beta_z = 0.98

        self.prev_error = [0.0] * 4
        self.error_sum = [0.0] * 4
        self.diff_prev = [0.0] * 4
        self.prev_output = [1500] * 4

        self.max_values = [2000] * 4
        self.min_values = [1000] * 4

        # --- ROS interfaces ---
        self.command_pub = self.create_publisher(SwiftMsgs, "/drone_command", 10)
        self.detect_pub = self.create_publisher(String, "/infected_plant_detected", 10)
        self.whycon_sub = self.create_subscription(PoseArray, "/whycon/poses", self.whycon_callback, 10)
        self.odom_sub = self.create_subscription(Odometry, "/rotors/odometry", self.odom_callback, 10)
        self.image_sub = self.create_subscription(Image, "/whycon/image_out", self.image_callback, 10)

        self.bridge = CvBridge()
        self.current_frame = None

        # --- Action server ---
        self._action_server = ActionServer(
            self, NavToWaypoint, "waypoint_navigation",
            execute_callback=self.execute_callback,
            callback_group=ReentrantCallbackGroup()
        )

        # --- Control loop ---
        self.create_timer(self.sample_time, self.pid)
        self.get_logger().info("🧭 Swift Pico Drone Final Mission Server (v2) Ready.")
        self.arm()

    # ---------------------------------------------------------------
    def arm(self):
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1500
        self.cmd.rc_aux4 = 2000
        self.command_pub.publish(self.cmd)
        self.get_logger().info("✅ Drone armed")

    def disarm(self):
        self.cmd.rc_roll = self.cmd.rc_pitch = self.cmd.rc_yaw = self.cmd.rc_throttle = 1000
        self.cmd.rc_aux4 = 1000
        self.command_pub.publish(self.cmd)
        self.get_logger().info("🛑 Drone disarmed")

    # ---------------------------------------------------------------
    def whycon_callback(self, msg: PoseArray):
        if not msg.poses:
            return
        p = msg.poses[0]
        self.current_state[:3] = [p.position.x, p.position.y, p.position.z]
        q = p.orientation
        _, _, yaw = euler_from_quaternion([q.x, q.y, q.z, q.w])
        self.current_state[3] = yaw

    def odom_callback(self, msg: Odometry):
        q = msg.pose.pose.orientation
        _, _, yaw = euler_from_quaternion([q.x, q.y, q.z, q.w])
        self.current_yaw = yaw
        if not self.initial_yaw_set:
            self.desired_yaw = yaw
            self.initial_yaw_set = True
            self.get_logger().info("Yaw reference set")

    def image_callback(self, msg: Image):
        try:
            self.current_frame = self.bridge.imgmsg_to_cv2(msg, "bgr8")
        except Exception as e:
            self.get_logger().warn(f"Image conversion failed: {e}")

    # ---------------------------------------------------------------
    def detect_infection(self):
        """Detect yellow-infected regions in the current camera frame."""
        if self.current_frame is None:
            return False
        frame = self.current_frame
        hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV)
        mask = cv2.inRange(hsv, HSV_YELLOW_RANGE[0], HSV_YELLOW_RANGE[1])
        ratio = np.count_nonzero(mask) / mask.size * 100
        return ratio > 1.0

    # ---------------------------------------------------------------
    def execute_callback(self, goal_handle):
        goal_pose = goal_handle.request.waypoint
        self.desired_state[:3] = [goal_pose.position.x, goal_pose.position.y, goal_pose.position.z]
        q = goal_pose.orientation
        _, _, self.desired_state[3] = euler_from_quaternion([q.x, q.y, q.z, q.w])

        x, y, z = self.desired_state[:3]
        stage = "NAV"
        if z > 32.0:
            stage = "PICKUP"
        elif z < PLANT_BLOCK_Z_THRESHOLD:
            stage = "BLOCK"

        self.get_logger().info(f"🎯 New waypoint → {x:.2f}, {y:.2f}, {z:.2f} | Stage: {stage}")

        result = NavToWaypoint.Result()
        hover_start = None

        while rclpy.ok():
            dist = math.dist(self.desired_state[:3], self.current_state[:3])

            # --- When drone reaches waypoint ---
            if dist < 0.4:
                # Handle stage-specific actions
                if stage == "PICKUP":
                    self.get_logger().info("🧴 Collecting pesticide...")
                    self.hover_action("PICKUP", 2.0)
                    goal_handle.succeed()
                    return result

                elif stage == "BLOCK":
                    infected = self.detect_infection()
                    msg = String()
                    msg.data = f"🧩 Plant at ({x:.2f},{y:.2f}) → {'INFECTED' if infected else 'HEALTHY'}"
                    self.detect_pub.publish(msg)
                    self.get_logger().info(msg.data)

                    if infected:
                        # Hover for inspection
                        self.hover_action("HOVER (Inspection)", 2.0)

                        # Descend and spray
                        spray_alt = z - 1.0
                        self.get_logger().info(f"🪜 Descending to {spray_alt:.2f} m for spraying...")
                        self.desired_state[2] = spray_alt
                        time.sleep(1.0)
                        self.hover_action("SPRAYING", 2.0)

                        # Return to hover altitude
                        self.desired_state[2] = spray_alt + 1.0
                        self.get_logger().info("⬆️ Returning to hover altitude.")

                    goal_handle.succeed()
                    return result

                else:
                    # Normal NAV waypoint (no hover pause)
                    goal_handle.succeed()
                    return result

            time.sleep(0.05)

        return result

    # ---------------------------------------------------------------
    def hover_action(self, label, duration):
        self.get_logger().info(f"🕒 {label} for {duration}s...")
        start = time.time()
        while time.time() - start < duration and rclpy.ok():
            self.command_pub.publish(self.cmd)
            time.sleep(0.03)

    # ---------------------------------------------------------------
    def pid(self):
        def clamp(v, lo, hi): return max(lo, min(v, hi))

        def compute(axis, tgt, val, pe, I, d_prev, beta, db):
            e = tgt - val
            if axis == 3:
                e = math.atan2(math.sin(e), math.cos(e))
            if abs(e) < db:
                e = 0.0
            I += e * self.sample_time
            I = clamp(I, -self.integral_limit, self.integral_limit)
            d_raw = (e - pe) / self.sample_time
            d = beta * d_prev + (1 - beta) * d_raw
            out = self.Kp[axis]*e + self.Ki[axis]*I + self.Kd[axis]*d
            return out, e, I, d

        # PID control axes
        out_x, ex, self.error_sum[0], self.diff_prev[0] = compute(0, self.desired_state[0], self.current_state[0],
                                                                  self.prev_error[0], self.error_sum[0], self.diff_prev[0],
                                                                  self.beta, self.deadband)
        out_y, ey, self.error_sum[1], self.diff_prev[1] = compute(1, self.current_state[1], self.desired_state[1],
                                                                  self.prev_error[1], self.error_sum[1], self.diff_prev[1],
                                                                  self.beta, self.deadband)
        out_z, ez, self.error_sum[2], self.diff_prev[2] = compute(2, self.desired_state[2], self.current_state[2],
                                                                  self.prev_error[2], self.error_sum[2], self.diff_prev[2],
                                                                  self.beta_z, self.deadband_z)
        out_yaw, eyaw, self.error_sum[3], self.diff_prev[3] = compute(3, self.desired_yaw or 0.0, self.current_yaw,
                                                                      self.prev_error[3], self.error_sum[3], self.diff_prev[3],
                                                                      self.beta, self.deadband)

        # RC outputs
        rc_thr = 1500 - out_z
        rc_pitch = 1500 + out_x
        rc_roll = 1500 - out_y
        rc_yaw = 1500 + out_yaw

        # Smoothing
        rc_thr = int(self.alpha_thr * self.prev_output[2] + (1 - self.alpha_thr) * rc_thr)
        rc_pitch = int(self.alpha_cmd * self.prev_output[0] + (1 - self.alpha_cmd) * rc_pitch)
        rc_roll = int(self.alpha_cmd * self.prev_output[1] + (1 - self.alpha_cmd) * rc_roll)
        rc_yaw = int(self.alpha_cmd * self.prev_output[3] + (1 - self.alpha_cmd) * rc_yaw)

        # Clamp
        self.cmd.rc_throttle = clamp(rc_thr, self.min_values[2], self.max_values[2])
        self.cmd.rc_pitch = clamp(rc_pitch, self.min_values[0], self.max_values[0])
        self.cmd.rc_roll = clamp(rc_roll, self.min_values[1], self.max_values[1])
        self.cmd.rc_yaw = clamp(rc_yaw, self.min_values[3], self.max_values[3])
        self.command_pub.publish(self.cmd)

        # Debug
        self.prev_error = [ex, ey, ez, eyaw]
        self.prev_output = [rc_pitch, rc_roll, rc_thr, rc_yaw]


# ---------------------------------------------------------------
def main(args=None):
    rclpy.init(args=args)
    node = WayPointServerFinal()
    executor = MultiThreadedExecutor(num_threads=3)
    executor.add_node(node)
    try:
        executor.spin()
    except KeyboardInterrupt:
        node.get_logger().info("KeyboardInterrupt – shutting down.")
    finally:
        node.disarm()
        executor.shutdown()
        node.destroy_node()
        rclpy.shutdown()


if __name__ == "__main__":
    main()
